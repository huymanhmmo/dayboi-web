---
/**
 * Footer.astro — Footer đa ngôn ngữ với thông tin liên hệ thật
 * Hiển thị logo, liên kết nhanh, thông tin liên hệ, và social links
 */
export interface Props {
  lang?: 'vi' | 'en';
}

const { lang = 'vi' } = Astro.props;

const currentYear = new Date().getFullYear();

const footerNav = lang === 'vi' ? {
  brand: 'Swim For Life Việt Nam',
  tagline: 'Trung tâm dạy bơi chuyên nghiệp hàng đầu Việt Nam. Đào tạo bơi lội cho mọi lứa tuổi với đội ngũ HLV giàu kinh nghiệm.',
  sections: [
    {
      title: 'Khóa Học',
      links: [
        { label: 'Bơi trẻ em', href: '/khoa-hoc-boi/tre-em/' },
        { label: 'Bơi người lớn', href: '/khoa-hoc-boi/nguoi-lon/' },
        { label: 'Lớp bơi nhóm nhỏ', href: '/khoa-hoc-boi/nhom/' },
        { label: 'Dạy bơi 1 kèm 1', href: '/khoa-hoc-boi/1-kem-1/' },
        { label: 'Lộ trình học bơi', href: '/lo-trinh-hoc-boi/' },
      ],
    },
    {
      title: 'Kỹ Thuật Bơi',
      links: [
        { label: 'Bơi ếch', href: '/ky-thuat-boi/hoc-boi-ech/' },
        { label: 'Bơi sải', href: '/ky-thuat-boi/hoc-boi-sai/' },
        { label: 'Bơi ngửa', href: '/ky-thuat-boi/hoc-boi-ngua/' },
        { label: 'Bơi bướm', href: '/ky-thuat-boi/hoc-boi-buom/' },
        { label: 'Kỹ năng đứng nước', href: '/ky-thuat-boi/ky-nang-dung-nuoc/' },
      ],
    },
    {
      title: 'Thông Tin',
      links: [
        { label: 'Giới thiệu', href: '/gioi-thieu/' },
        { label: 'Đội ngũ HLV', href: '/doi-ngu-hlv/' },
        { label: 'Bảng giá', href: '/bang-gia/' },
        { label: 'Blog', href: '/tin-tuc/' },
        { label: 'Liên hệ', href: '/lien-he/' },
      ],
    },
  ],
  contact: {
    title: 'Liên Hệ Ngay',
    phone: '0979.121.097',
    email: 'dayboivip@gmail.com',
    zaloLabel: 'Chat Zalo',
    zaloHref: 'http://zalo.me/0979121097',
    ctaLabel: 'Liên Hệ Nhận Tư Vấn Miễn Phí',
    ctaHref: '/lien-he/',
  },
  copyright: `© ${currentYear} Swim For Life Việt Nam. Thuộc Công ty CP Your Dreams. Bảo lưu mọi quyền.`,
} : {
  brand: 'Swim For Life Vietnam',
  tagline: 'Leading professional swimming center in Vietnam. Swimming training for all ages with experienced coaches.',
  sections: [
    {
      title: 'Courses',
      links: [
        { label: 'Kids Swimming', href: '/en/courses/kids/' },
        { label: 'Adult Swimming', href: '/en/courses/adults/' },
        { label: 'Intensive Course', href: '/en/courses/intensive/' },
        { label: 'Swim Journey', href: '/en/swim-journey/' },
      ],
    },
    {
      title: 'Techniques',
      links: [
        { label: 'Breaststroke', href: '/en/swimming-techniques/breaststroke/' },
        { label: 'Front Crawl', href: '/en/swimming-techniques/front-crawl/' },
        { label: 'Backstroke', href: '/en/swimming-techniques/backstroke/' },
        { label: 'Butterfly', href: '/en/swimming-techniques/butterfly/' },
      ],
    },
    {
      title: 'Information',
      links: [
        { label: 'About Us', href: '/en/about/' },
        { label: 'Coaches', href: '/en/coaches/' },
        { label: 'Pricing', href: '/en/pricing/' },
        { label: 'Blog', href: '/en/blog/' },
        { label: 'Contact', href: '/en/contact/' },
      ],
    },
  ],
  contact: {
    title: 'Contact Us',
    phone: '0979.121.097',
    email: 'dayboivip@gmail.com',
    zaloLabel: 'Chat on Zalo',
    zaloHref: 'http://zalo.me/0979121097',
    ctaLabel: 'Get Free Consultation',
    ctaHref: '/en/contact/',
  },
  copyright: `© ${currentYear} Swim For Life Vietnam. Part of Your Dreams JSC. All rights reserved.`,
};
---

<footer class="footer" id="site-footer">
  <!-- Wave decoration -->
  <div class="footer__wave">
    <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,60 C240,120 480,0 720,60 C960,120 1200,0 1440,60 L1440,120 L0,120 Z" fill="var(--color-footer-bg)" />
    </svg>
  </div>

  <div class="footer__body">
    <div class="container">
      <div class="footer__grid">
        <!-- Brand Column -->
        <div class="footer__brand">
          <a href={lang === 'vi' ? '/' : '/en/'} class="footer__logo-link">
            <img 
              src="/images/brand/logo.png" 
              alt={footerNav.brand} 
              class="footer__logo-img"
              width="200" 
              height="55" 
              loading="lazy"
            />
          </a>
          <p class="footer__tagline">{footerNav.tagline}</p>
          
          <!-- Contact Info -->
          <div class="footer__contact-info">
            <a href={`tel:${footerNav.contact.phone.replace(/\./g, '')}`} class="footer__contact-item">
              <svg class="footer__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              <span>{footerNav.contact.phone}</span>
            </a>
            <a href={`mailto:${footerNav.contact.email}`} class="footer__contact-item">
              <svg class="footer__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22,7-8.97,5.7a1.94,1.94 0 0 1-2.06,0L2,7"/></svg>
              <span>{footerNav.contact.email}</span>
            </a>
            <a href={footerNav.contact.zaloHref} target="_blank" rel="noopener noreferrer" class="footer__contact-item footer__contact-item--zalo">
              <svg class="footer__icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.037 0 11.25c0 3.52 1.687 6.656 4.323 8.743-.12.94-.544 3.448-.624 4.007 0 0-.013.083.04.117a.15.15 0 0 0 .132.002c.53-.09 3.073-1.995 3.735-2.482A13.3 13.3 0 0 0 12 22.5c6.627 0 12-5.037 12-11.25S18.627 0 12 0z"/></svg>
              <span>{footerNav.contact.zaloLabel}</span>
            </a>
          </div>
        </div>

        <!-- Navigation Columns -->
        {footerNav.sections.map((section) => (
          <div class="footer__nav-col">
            <h3 class="footer__nav-title">{section.title}</h3>
            <ul class="footer__nav-list">
              {section.links.map((link) => (
                <li>
                  <a href={link.href} class="footer__nav-link">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <!-- CTA Banner -->
      <div class="footer__cta-banner">
        <div class="footer__cta-content">
          <p class="footer__cta-text">
            {lang === 'vi' 
              ? '🏊 Bạn muốn học bơi? Liên hệ ngay để nhận tư vấn miễn phí!' 
              : '🏊 Want to learn swimming? Contact us for a free consultation!'}
          </p>
          <div class="footer__cta-actions">
            <a href={`tel:${footerNav.contact.phone.replace(/\./g, '')}`} class="btn btn--accent btn--sm">
              📞 {footerNav.contact.phone}
            </a>
            <a href={footerNav.contact.zaloHref} target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--sm">
              💬 {footerNav.contact.zaloLabel}
            </a>
          </div>
        </div>
      </div>

      <!-- Bottom Bar -->
      <div class="footer__bottom">
        <p class="footer__copyright">{footerNav.copyright}</p>
        <div class="footer__bottom-links">
          <a href={lang === 'vi' ? '/' : '/en/'}>
            {lang === 'vi' ? 'Trang chủ' : 'Home'}
          </a>
          <span class="footer__sep">•</span>
          <a href="https://dayboi.vip" target="_blank" rel="noopener">dayboi.vip</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<!-- Floating Zalo Button -->
<a 
  href="http://zalo.me/0979121097" 
  target="_blank" 
  rel="noopener noreferrer"
  class="floating-zalo" 
  aria-label="Chat Zalo"
  id="floating-zalo-btn"
>
  <span class="floating-zalo__pulse"></span>
  <span class="floating-zalo__icon">
    <svg viewBox="0 0 24 24" fill="white" width="28" height="28"><path d="M12 0C5.373 0 0 5.037 0 11.25c0 3.52 1.687 6.656 4.323 8.743-.12.94-.544 3.448-.624 4.007 0 0-.013.083.04.117a.15.15 0 0 0 .132.002c.53-.09 3.073-1.995 3.735-2.482A13.3 13.3 0 0 0 12 22.5c6.627 0 12-5.037 12-11.25S18.627 0 12 0z"/></svg>
  </span>
</a>

<!-- Floating Phone Button -->
<a 
  href="tel:0979121097" 
  class="floating-phone" 
  aria-label="Gọi ngay 0979.121.097"
  id="floating-phone-btn"
>
  <span class="floating-phone__pulse"></span>
  <span class="floating-phone__icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" width="24" height="24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
  </span>
</a>

<style>
  /* ============================================
     Footer Design — Vibrant Aqua & Coral
     ============================================ */

  :root {
    --color-footer-bg: #0a1628;
    --color-footer-text: #b0bec5;
    --color-footer-heading: #ffffff;
    --color-footer-link: #90caf9;
    --color-footer-link-hover: #00B4D8;
    --color-zalo: #0068FF;
  }

  .footer__wave {
    margin-top: -2px;
    line-height: 0;
  }

  .footer__wave svg {
    width: 100%;
    height: 80px;
    display: block;
  }

  .footer__body {
    background: var(--color-footer-bg);
    padding: var(--space-10) 0 var(--space-6);
  }

  /* Grid */
  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: var(--space-8);
    padding-bottom: var(--space-8);
  }

  /* Brand */
  .footer__logo-link {
    display: inline-block;
    margin-bottom: var(--space-4);
  }

  .footer__logo-img {
    height: 48px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.95;
    transition: opacity var(--transition-fast);
  }

  .footer__logo-link:hover .footer__logo-img {
    opacity: 1;
  }

  .footer__tagline {
    color: var(--color-footer-text);
    font-size: var(--text-sm);
    line-height: 1.7;
    margin-bottom: var(--space-5);
  }

  /* Contact Info */
  .footer__contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-footer-text);
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .footer__contact-item:hover {
    color: var(--color-footer-link-hover);
  }

  .footer__contact-item--zalo:hover {
    color: var(--color-zalo);
  }

  .footer__icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    opacity: 0.7;
  }

  /* Nav Columns */
  .footer__nav-title {
    color: var(--color-footer-heading);
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: var(--space-4);
    position: relative;
    padding-bottom: var(--space-2);
  }

  .footer__nav-title::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 32px;
    height: 2px;
    background: var(--gradient-primary);
    border-radius: 2px;
  }

  .footer__nav-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__nav-link {
    color: var(--color-footer-text);
    font-size: var(--text-sm);
    transition: all var(--transition-fast);
    padding: 2px 0;
  }

  .footer__nav-link:hover {
    color: var(--color-footer-link-hover);
    padding-left: 6px;
  }

  /* CTA Banner */
  .footer__cta-banner {
    margin: var(--space-8) 0;
    background: linear-gradient(135deg, rgba(0, 103, 125, 0.08), rgba(255, 145, 0, 0.08));
    border-radius: var(--radius-xl);
    padding: var(--space-6);
  }

  .footer__cta-content {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .footer__cta-text {
    color: var(--color-footer-heading);
    font-size: 1.05rem;
    font-weight: 600;
  }

  .footer__cta-actions {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  /* Bottom */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: var(--space-6);
  }

  .footer__copyright {
    color: var(--color-footer-text);
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .footer__bottom-links {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer__bottom-links a {
    color: var(--color-footer-text);
    font-size: 0.8rem;
    opacity: 0.7;
    transition: all var(--transition-fast);
  }

  .footer__bottom-links a:hover {
    color: var(--color-footer-link-hover);
    opacity: 1;
  }

  .footer__sep {
    color: var(--color-footer-text);
    opacity: 0.3;
    font-size: 0.7rem;
  }

  /* ============================================
     Floating Buttons (Zalo + Phone)
     ============================================ */

  .floating-zalo,
  .floating-phone {
    position: fixed;
    z-index: 999;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .floating-zalo {
    bottom: 100px;
    right: 24px;
    background: var(--color-zalo);
  }

  .floating-phone {
    bottom: 32px;
    right: 24px;
    background: var(--color-accent);
  }

  .floating-zalo:hover,
  .floating-phone:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 28px rgba(0, 0, 0, 0.35);
  }

  .floating-zalo__icon,
  .floating-phone__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }

  .floating-zalo__pulse,
  .floating-phone__pulse {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    animation: floatingPulse 2s ease-in-out infinite;
  }

  .floating-zalo__pulse {
    background: var(--color-zalo);
  }

  .floating-phone__pulse {
    background: var(--color-accent);
  }

  @keyframes floatingPulse {
    0% { transform: scale(1); opacity: 0.6; }
    50% { transform: scale(1.3); opacity: 0; }
    100% { transform: scale(1); opacity: 0; }
  }

  /* ============================================
     Responsive
     ============================================ */

  @media (max-width: 1024px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 640px) {
    .footer__grid {
      grid-template-columns: 1fr;
    }

    .footer__cta-content {
      flex-direction: column;
      text-align: center;
    }

    .footer__cta-actions {
      justify-content: center;
    }

    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }

    .floating-zalo,
    .floating-phone {
      width: 50px;
      height: 50px;
      right: 16px;
    }

    .floating-zalo {
      bottom: 84px;
    }

    .floating-phone {
      bottom: 24px;
    }

    .footer__wave svg {
      height: 50px;
    }
  }
</style>
