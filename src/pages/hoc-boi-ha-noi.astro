  }

  .bubble--1 { width: 40px; height: 40px; left: 10%; bottom: -10%; animation-delay: 0s; animation-duration: 12s; }
  .bubble--2 { width: 60px; height: 60px; left: 25%; bottom: -15%; animation-delay: 2s; animation-duration: 15s; }
  .bubble--3 { width: 30px; height: 30px; left: 70%; bottom: -10%; animation-delay: 1s; animation-duration: 9s; }
  .bubble--4 { width: 50px; height: 50px; left: 85%; bottom: -20%; animation-delay: 4s; animation-duration: 14s; }
  .bubble--5 { width: 25px; height: 25px; left: 45%; bottom: -5%; animation-delay: 3s; animation-duration: 10s; }

  @keyframes floatUp {
    0% { transform: translateY(0) scale(1) rotate(0deg); opacity: 0; }
    50% { opacity: 0.5; }
    100% { transform: translateY(-100vh) scale(1.2) rotate(360deg); opacity: 0; }
  }

  .hanoi-hero__grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: var(--space-10);
    align-items: center;
  }

  .hanoi-hero__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: rgba(0, 180, 216, 0.12);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 180, 216, 0.25);
    padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-full);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary-light);
    margin-bottom: var(--space-6);
  }

  .hanoi-hero__badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 10px var(--color-accent);
    animation: dotPulse 2s infinite ease-in-out;
  }

  @keyframes dotPulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.4); opacity: 0.6; }
  }

  .hanoi-hero__title {
    font-size: clamp(2rem, 4vw, 3.25rem);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    margin-bottom: var(--space-4);
  }

  .hanoi-hero__desc {
    color: rgba(255, 255, 255, 0.8);
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
    line-height: 1.7;
    margin-bottom: var(--space-6);
  }

  .hanoi-hero__value-props {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .v-prop {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .v-prop__icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .v-prop__content {
    display: flex;
    flex-direction: column;
  }

  .v-prop__content strong {
    color: #fff;
    font-size: 1rem;
    font-weight: 600;
  }

  .v-prop__content span {
    color: rgba(255, 255, 255, 0.65);
    font-size: 0.85rem;
  }

  .hanoi-hero__actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .btn--hero-outline {
    background: transparent;
    border: 2px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    transition: all var(--transition-base);
  }

  .btn--hero-outline:hover {
    background: #fff;
    color: var(--color-text);
    border-color: #fff;
  }

  /* --- Visual Collage --- */
  .hanoi-hero__visual {
    position: relative;
    height: 560px;
    width: 100%;
  }

  .hanoi-hero__visual::before,
  .hanoi-hero__visual::after {
    content: '';
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    z-index: 0;
  }

  .hanoi-hero__visual::before {
    width: 250px;
    height: 250px;
    bottom: -60px;
    left: 5%;
    background: radial-gradient(circle, rgba(0, 200, 255, 0.1) 0%, transparent 70%);
    animation: waterBubble 6s ease-in-out infinite;
  }

  .hanoi-hero__visual::after {
    width: 180px;
    height: 180px;
    top: -20px;
    right: 0;
    background: radial-gradient(circle, rgba(0, 180, 216, 0.08) 0%, transparent 70%);
    animation: waterBubble 8s ease-in-out infinite 2s;
  }

  @keyframes waterBubble {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.6; }
    50% { transform: translateY(-20px) scale(1.15); opacity: 1; }
  }

  .hanoi-hero__collage {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .hanoi-hero__water-bubbles {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .hanoi-hero__collage .hanoi-hero__photo {
    position: absolute;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    transition: transform 0.5s ease;
  }

  .hanoi-hero__collage .hanoi-hero__photo:hover {
    transform: scale(1.03);
  }

  .hanoi-hero__collage .hanoi-hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hanoi-hero__photo--main {
    width: 75%;
    height: 65%;
    top: 10%;
    left: 0;
    z-index: 2;
    border: 3px solid rgba(0, 180, 216, 0.3);
  }

  .hanoi-hero__photo--top {
    width: 45%;
    height: 40%;
    top: 0;
    right: 0;
    z-index: 1;
    border: 3px solid rgba(255, 255, 255, 0.15);
  }

  .hanoi-hero__photo--bottom {
    width: 50%;
    height: 42%;
    bottom: 0;
    right: 5%;
    z-index: 3;
    border: 3px solid rgba(255, 107, 53, 0.3);
  }

  /* --- Floating Stat Cards --- */
  .hanoi-hero__float-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    z-index: 10;
    animation: floatStat 4s ease-in-out infinite;
  }

  .hanoi-hero__float-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .hanoi-hero__float-card strong {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    font-family: var(--font-heading);
    display: block;
  }

  .hanoi-hero__float-card span {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.65);
    white-space: nowrap;
  }

  .hanoi-hero__float-card--top {
    top: 2%;
    left: 30%;
    animation-delay: 0s;
  }

  .hanoi-hero__float-card--bottom {
    bottom: 5%;
    left: -5%;
    animation-delay: 1.5s;
  }

  .hanoi-hero__float-card--left {
    bottom: 30%;
    right: -5%;
    animation-delay: 0.8s;
  }

  @keyframes floatStat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* ============================================
     STATISTICS SECTION (FULL WIDTH)
     ============================================ */
  .hanoi-stats-section {
    background: var(--color-bg-card);
    border-block: 1px solid var(--color-border-light);
    padding-block: var(--space-8);
  }

  .hanoi-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
    text-align: center;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-inline: var(--space-4);
  }

  .stat-item:not(:last-child) {
    border-right: 1px solid var(--color-border);
  }

  .stat-item__num {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1;
  }

  .stat-item__label {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  /* ============================================
     INTRO SECTION
     ============================================ */
  .hanoi-intro-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .hanoi-intro-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .intro-feat {
    display: flex;
    gap: var(--space-3);
    align-items: flex-start;
  }

  .intro-feat__icon {
    font-size: 1.1rem;
    line-height: 1.4;
  }

  .intro-feat span {
    font-size: 0.9rem;
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.4;
  }

  .hanoi-intro-image-wrap {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .hanoi-intro-img {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .img-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(0,0,0,0.8));
    color: #fff;
    padding: var(--space-5) var(--space-4) var(--space-3);
    font-size: 0.85rem;
    text-align: center;
    font-weight: 500;
  }

  /* ============================================
     PARTNER POOLS SECTION
     ============================================ */
  .hanoi-pools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  .pool-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all var(--transition-smooth);
    box-shadow: var(--shadow-sm);
  }

  .pool-card:hover {
    transform: translateY(-6px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-xl), 0 0 20px rgba(0, 180, 216, 0.1);
  }

  .pool-card__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-4);
  }

  .pool-card__icon {
    font-size: 1.8rem;
    line-height: 1;
  }

  .pool-card__badge {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--color-primary);
    background: rgba(0, 180, 216, 0.08);
    padding: 3px 8px;
    border-radius: var(--radius-sm);
  }

  .pool-card__title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .pool-card__detail {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-2);
    line-height: 1.5;
  }

  .pool-card__pros {
    border-top: 1px solid var(--color-border-light);
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .pool-card__pros strong {
    display: block;
    color: var(--color-primary);
    margin-bottom: 2px;
  }

  .pool-card__footer {
    margin-top: var(--space-6);
    border-top: 1px solid var(--color-border-light);
    padding-top: var(--space-4);
  }

  .pool-card__btn {
    display: block;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .pool-card:hover .pool-card__btn {
    color: var(--color-accent);
  }

  /* Custom Request Pool Card */
  .pool-card--request {
    background: var(--color-bg-alt);
    border: 2px dashed var(--color-primary);
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .pool-card__request-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }

  .request-icon {
    font-size: 2rem;
    line-height: 1;
  }

  .pool-card__request-desc {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    max-width: 250px;
  }

  /* ============================================
     COURSE PROGRAMS SECTION
     ============================================ */
  .hanoi-programs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-10);
  }

  .program-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all var(--transition-smooth);
    box-shadow: var(--shadow-sm);
  }

  .program-card:hover {
    transform: translateY(-6px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-xl);
  }

  .program-card__img-wrap {
    position: relative;
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .program-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-smooth);
  }

  .program-card:hover .program-card__img-wrap img {
    transform: scale(1.05);
  }

  .program-card__tag {
    position: absolute;
    top: var(--space-4);
    left: var(--space-4);
    background: var(--color-primary);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: var(--radius-sm);
  }

  .program-card__tag--orange { background: var(--color-accent); }
  .program-card__tag--green { background: #0CA789; }

  .program-card__body {
    padding: var(--space-6);
    flex-grow: 1;
  }

  .program-card__title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .program-card__desc {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-4);
  }

  .program-card__list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: 0.8rem;
    color: var(--color-text);
    font-weight: 600;
    border-top: 1px solid var(--color-border-light);
    padding-top: var(--space-4);
  }

  .program-card__list li {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .program-card__list li::before {
    content: '🔹';
    font-size: 0.8rem;
  }

  .program-card__footer {
    padding: var(--space-6);
    padding-top: 0;
  }

  .btn--full {
    width: 100%;
    text-align: center;
    display: block;
  }

  /* ============================================
     SWIM TECHNIQUES PREVIEW
     ============================================ */
  .techniques-section {
    background: var(--color-bg);
  }

  .techniques-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-5);
    margin-top: var(--space-8);
  }

  .technique-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
    transition: all var(--transition-smooth);
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .technique-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
    border-color: var(--color-primary);
  }

  .technique-card__img-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .technique-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .technique-card:hover .technique-card__img-wrap img {
    transform: scale(1.08);
  }

  .technique-card__body {
    padding: var(--space-5);
  }

  .technique-card__number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-primary);
    opacity: 0.25;
    line-height: 1;
  }

  .technique-card__title {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text);
    margin: var(--space-2) 0;
  }

  .technique-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .technique-card__link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .technique-card:hover .technique-card__link {
    color: var(--color-accent);
  }

  /* ============================================
     PRICING SECTION
     ============================================ */
  .hanoi-pricing-section {
    background: var(--color-bg-alt);
  }

  .hanoi-pricing-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin-top: var(--space-10);
    align-items: stretch;
  }

  .pricing-card {
    background: #ffffff;
    border-radius: 16px;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all var(--transition-smooth);
    box-shadow: var(--shadow-md);
    position: relative;
  }

  .pricing-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-xl);
  }

  .pricing-card--primary {
    border-top: 5px solid var(--color-primary);
  }

  .pricing-card--teal {
    border-top: 5px solid var(--color-teal);
  }

  .pricing-card--featured {
    border: 2px solid var(--color-accent);
    border-top: 6px solid var(--color-accent);
    box-shadow: var(--shadow-xl);
    transform: translateY(-4px);
  }

  .pricing-card--featured:hover {
    transform: translateY(-10px);
    box-shadow: var(--shadow-xl), 0 10px 30px rgba(255, 107, 53, 0.15);
  }

  .badge-popular {
    position: absolute;
    top: -14px;
    right: 20px;
    background: var(--color-accent);
    color: #fff;
    padding: 2px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    z-index: 10;
  }

  .pricing-card__sub {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-primary);
    font-weight: 700;
    display: block;
    margin-bottom: var(--space-2);
  }

  .pricing-card__sub--teal {
    color: var(--color-teal);
  }

  .pricing-card__sub--accent {
    color: var(--color-accent);
  }

  .pricing-card__title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .pricing-card__desc {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    line-height: 1.5;
  }

  .pricing-card__price {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .pricing-card__features {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--color-text);
    list-style: none;
    padding: 0;
  }

  .pricing-card__features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
  }

  .pricing-card__features li span:first-child {
    flex-shrink: 0;
  }

  .pricing-card__footer {
    margin-top: auto;
  }

  .pricing-note {
    margin-top: var(--space-8);
    background: var(--color-bg-card);
    padding: var(--space-4) var(--space-6);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-primary);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .pricing-note p {
    margin: 0;
    line-height: 1.6;
  }

  /* ============================================
     COACHES SECTION
     ============================================ */
  /* Featured Coach Spotlight */
  .featured-coach {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-8);
    background: linear-gradient(135deg, #ffffff 0%, #f7f9fc 100%);
    border-radius: var(--radius-2xl);
    border: 2px solid var(--color-accent);
    padding: var(--space-6);
    box-shadow: 0 12px 30px rgba(255, 145, 0, 0.06);
    margin-bottom: var(--space-8);
    position: relative;
    overflow: hidden;
  }

  .featured-coach::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 150px;
    height: 150px;
    background: radial-gradient(circle, rgba(255, 145, 0, 0.08) 0%, transparent 70%);
    pointer-events: none;
  }

  .featured-coach__img-wrap {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    height: 320px;
    box-shadow: var(--shadow-md);
  }

  .featured-coach__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-smooth);
  }

  .featured-coach:hover .featured-coach__img {
    transform: scale(1.03);
  }

  .featured-coach__badge {
    position: absolute;
