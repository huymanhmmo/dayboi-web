---
import PageLayout from '../../layouts/PageLayout.astro';
import RegistrationForm from '../../components/RegistrationForm.astro';
import SuccessModal from '../../components/SuccessModal.astro';
import { blogPosts } from '../../data/blogPosts.js';

export async function getStaticPaths() {
  const tagsMap = new Map();
  blogPosts.forEach(post => {
    if (post.tags && post.tagSlugs) {
      post.tags.forEach((tag, idx) => {
        const slug = post.tagSlugs[idx];
        if (slug) {
          if (!tagsMap.has(slug)) {
            tagsMap.set(slug, {
              name: tag,
              slug: slug,
              posts: []
            });
          }
          tagsMap.get(slug).posts.push(post);
        }
      });
    }
  });

  return Array.from(tagsMap.values()).map(tagItem => ({
    params: { tag: tagItem.slug },
    props: { tagName: tagItem.name, posts: tagItem.posts }
  }));
}

const { tag } = Astro.params;
const { tagName, posts } = Astro.props;

const currentYear = new Date().getFullYear();
const title = `Thẻ bài viết: ${tagName} | Blog Dạy Bơi`;
const description = `Các bài viết hữu ích được gắn thẻ ${tagName} từ Trung tâm dạy bơi Swim For Life Việt Nam.`;

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: 'Tin tức', href: '/tin-tuc/' },
  { label: tagName },
];

const formattedBlogPosts = posts.map(post => {
  if (post.slug === 'cach-hoc-boi' || post.slug === 'tu-hoc-boi') {
    return {
      ...post,
      title: `${post.title} [${currentYear}]`
    };
  }
  return post;
});

const featuredPost = formattedBlogPosts[0];
const remainingPosts = formattedBlogPosts.slice(1);

// Compute Category counts dynamically
const categoriesMap = new Map();
blogPosts.forEach(post => {
  if (post.category && post.categorySlug) {
    if (!categoriesMap.has(post.categorySlug)) {
      categoriesMap.set(post.categorySlug, {
        name: post.category,
        slug: post.categorySlug,
        count: 0
      });
    }
    categoriesMap.get(post.categorySlug).count += 1;
  }
});
const categoriesList = Array.from(categoriesMap.values());

// Compute Tag counts dynamically
const tagsMap = new Map();
blogPosts.forEach(post => {
  if (post.tags && post.tagSlugs) {
    post.tags.forEach((t, idx) => {
      const slug = post.tagSlugs[idx];
      if (slug) {
        if (!tagsMap.has(slug)) {
          tagsMap.set(slug, {
            name: t,
            slug: slug,
            count: 0
          });
        }
        tagsMap.get(slug).count += 1;
      }
    });
  }
});
const tagsList = Array.from(tagsMap.values());

const categories = [
  { name: 'Tất cả', slug: '' },
  { name: 'Hướng Dẫn Học Bơi', slug: 'huong-dan-hoc-boi' },
  { name: 'Bơi Lội Trẻ Em', slug: 'boi-loi-tre-em' },
  { name: 'Kỹ Thuật Bơi Lội', slug: 'ky-thuat-boi-loi' },
  { name: 'Kinh Nghiệm & Thiết Bị', slug: 'kinh-nghiem-thiet-bi' },
];
---

<PageLayout
  title={title}
  description={description}
  canonical={`https://dayboi.vip/the/${tag}/`}
  breadcrumbs={breadcrumbs}
>

<!-- Blog Header -->
<section class="section" style="padding-top: var(--space-8); padding-bottom: var(--space-8); background: var(--color-bg-alt); border-bottom: 1px solid rgba(0, 119, 182, 0.05);">
  <div class="container container-wide">
    <div class="section-header" style="margin-bottom: 0;">
      <span class="section-badge">🏷️ Thẻ tag</span>
      <h1 class="section-title">{tagName}</h1>
      <p class="section-subtitle">
        Xem tất cả các bài viết được gắn thẻ "{tagName}" được chia sẻ bởi đội ngũ Huấn luyện viên tại Swim For Life.
      </p>
    </div>
  </div>
</section>

<!-- Blog News Portal Layout -->
<section class="section" style="padding-top: var(--space-12); padding-bottom: var(--space-20);">
  <div class="container container-wide">
    <div class="news-layout">
      
      <!-- Main Column (Left): Featured Post + Grid -->
      <div class="news-main">
        <!-- Category Filter Bar (Horizontal) -->
        <div class="category-filter-nav">
          {categories.map(cat => (
            <a 
              href={cat.slug ? `/${cat.slug}/` : '/tin-tuc/'} 
              class="category-filter-link"
            >
              {cat.name}
            </a>
          ))}
        </div>

        {featuredPost && (
          <article class="featured-news-card">
            <a href={`/${featuredPost.slug}/`} class="featured-news-card-link">
              <div class="featured-card-image-wrapper">
                <img
                  src={featuredPost.image}
                  alt={featuredPost.title}
                  class="featured-card-image"
                  loading="eager"
                  width="640"
                  height="360"
                />
              </div>
              <div class="featured-card-content">
                <div class="featured-card-meta">
                  <span class="featured-card-category">{featuredPost.category}</span>
                  <span class="featured-card-read-time">{featuredPost.readTime} đọc</span>
                </div>
                
                <h2 class="featured-card-title">{featuredPost.title}</h2>
                <p class="featured-card-excerpt">{featuredPost.excerpt}</p>
                
                {featuredPost.tags && featuredPost.tags.length > 0 && (
                  <div class="card-tags-list" style="margin-bottom: var(--space-4);">
                    {featuredPost.tags.map((t) => (
                      <span class={`card-tag-item ${t === tagName ? 'active-tag' : ''}`} style={t === tagName ? "background: var(--color-primary); color: #ffffff;" : ""}>
                        {t}
                      </span>
                    ))}
                  </div>
                )}
                
                <span class="featured-card-more">Đọc bài viết →</span>
              </div>
            </a>
          </article>
        )}

        <div class="news-grid">
          {remainingPosts.map((post) => (
            <article class="news-card">
              <a href={`/${post.slug}/`} class="news-card-link">
                <div class="news-card-image-wrapper">
                  <img
                    src={post.image}
                    alt={post.title}
                    class="news-card-image"
                    loading="lazy"
                    width="400"
                    height="220"
                  />
                </div>
                <div class="news-card-content">
                  <div class="news-card-meta">
                    <span class="news-card-category">{post.category}</span>
                    <span class="news-card-read-time">{post.readTime} đọc</span>
                  </div>
                  
                  <h3 class="news-card-title">{post.title}</h3>
                  <p class="news-card-excerpt">{post.excerpt}</p>
                  
                  {post.tags && post.tags.length > 0 && (
                    <div class="card-tags-list">
                      {post.tags.map((t) => (
                        <span class={`card-tag-item ${t === tagName ? 'active-tag' : ''}`} style={t === tagName ? "background: var(--color-primary); color: #ffffff;" : ""}>
                          {t}
                        </span>
                      ))}
                    </div>
                  )}
                  
                  <span class="news-card-more">Đọc bài viết →</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>

      <!-- Sidebar Column (Right): Sticky Widgets -->
      <aside class="news-sidebar">
        <!-- Widget: Categories -->
        <div class="sidebar-widget">
          <h3 class="widget-title">📁 Danh Mục</h3>
          <ul class="sidebar-categories-list">
            {categoriesList.map(cat => (
              <li>
                <a href={`/${cat.slug}/`} class="category-item-link">
                  <span class="category-name">{cat.name}</span>
                  <span class="category-count">({cat.count})</span>
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Widget: Tag Cloud -->
        {tagsList && tagsList.length > 0 && (
          <div class="sidebar-widget">
            <h3 class="widget-title">🏷️ Đám Mây Thẻ</h3>
            <div class="tag-cloud">
              {tagsList.map(tagItem => (
                <a href={`/the/${tagItem.slug}/`} class={`tag-cloud-item ${tagItem.slug === tag ? 'active-tag-cloud' : ''}`} style={tagItem.slug === tag ? "background: var(--color-primary); color: #ffffff !important;" : ""}><span class="tag-name">{tagItem.name}</span> <span class="tag-count" style={tagItem.slug === tag ? "background: #ffffff; color: var(--color-primary);" : ""}>({tagItem.count})</span></a>
              ))}
            </div>
          </div>
        )}

        <!-- Widget: Form Registration -->
        <div class="sidebar-widget">
          <h3 class="widget-title">🏊 Đăng Ký Học Thử</h3>
          <p class="widget-subtitle">Nhận ngay 1 buổi học thử 1 kèm 1 miễn phí cùng HLV chuyên nghiệp tại bể bơi gần nhà bạn nhất!</p>
          <RegistrationForm id="blog-register-form" />
          <div class="widget-trust">
            🔒 Bảo mật thông tin • Cam kết biết bơi 100%
          </div>
        </div>
      </aside>

    </div>
  </div>
</section>

<!-- CTA -->
<section class="section-sm" style="background: var(--color-bg-alt); border-top: 1px solid rgba(0, 119, 182, 0.05);">
  <div class="container">
    <div class="cta-banner">
      <h2>Bạn Muốn Học Bơi Chuyên Nghiệp?</h2>
      <p>Đăng ký học thử miễn phí với HLV Swim For Life ngay hôm nay!</p>
      <div class="btn-group">
        <a href="/lien-he/" class="btn btn-accent btn-lg">Đăng Ký Học Thử Miễn Phí</a>
        <a href="/khoa-hoc-boi/" class="btn btn-white btn-lg">Xem Khóa Học</a>
      </div>
    </div>
  </div>
</section>

<SuccessModal />

</PageLayout>

