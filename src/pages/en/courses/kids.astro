---
const currentYear = new Date().getFullYear();
import CourseLayout from '../../../layouts/CourseLayout.astro';
import { kids } from '../../../data/coursesEn.js';

const breadcrumbs = [
  { label: 'Home', href: '/en/' },
  { label: 'Swimming Courses', href: '/en/courses/' },
  { label: 'Kids Swimming Lessons' },
];

import { generateCourseSchema } from '../../../utils/courseSchema.js';
const courseSchema = generateCourseSchema(kids, 'https://dayboi.vip/en/courses/kids/');

const combinedSchema = [courseSchema];
---

<CourseLayout
  course={kids}
  breadcrumbs={breadcrumbs}
  schema={combinedSchema}
  lang="en"
/>
