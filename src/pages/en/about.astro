    background: radial-gradient(circle, rgba(0, 200, 255, 0.1) 0%, transparent 70%);
    animation: waterBubble 6s ease-in-out infinite;
  }

  .about-hero__visual::after {
    width: 180px;
    height: 180px;
    top: -20px;
    right: 0;
    background: radial-gradient(circle, rgba(0, 180, 216, 0.08) 0%, transparent 70%);
    animation: waterBubble 8s ease-in-out infinite 2s;
  }

  @keyframes waterBubble {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.6; }
    50% { transform: translateY(-20px) scale(1.15); opacity: 1; }
  }

  .about-hero__collage {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  /* Water Bubbles inside visual */
  .about-hero__water-bubbles {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .about-hero__collage .about-hero__photo {
    position: absolute;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4);
    transition: transform 0.5s ease;
  }

  .about-hero__collage .about-hero__photo:hover {
    transform: scale(1.03);
  }

  .about-hero__collage .about-hero__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-hero__photo--main {
    width: 75%;
    height: 65%;
    top: 10%;
    left: 0;
    z-index: 2;
    border: 3px solid rgba(0, 180, 216, 0.3);
  }

  .about-hero__photo--top {
    width: 45%;
    height: 40%;
    top: 0;
    right: 0;
    z-index: 1;
    border: 3px solid rgba(255, 255, 255, 0.15);
  }

  .about-hero__photo--bottom {
    width: 50%;
    height: 42%;
    bottom: 0;
    right: 5%;
    z-index: 3;
    border: 3px solid rgba(255, 107, 53, 0.3);
  }

  /* --- Floating Stat Cards --- */
  .about-hero__float-card {
    position: absolute;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    z-index: 10;
    animation: floatStat 4s ease-in-out infinite;
  }

  .about-hero__float-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .about-hero__float-card strong {
    color: #fff;
    font-size: 0.95rem;
    font-weight: 700;
    font-family: var(--font-heading);
    display: block;
  }

  .about-hero__float-card span {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.65);
  }

  .about-hero__float-card--top {
    top: 2%;
    left: 30%;
    animation-delay: 0s;
  }

  .about-hero__float-card--bottom {
    bottom: 5%;
    left: -5%;
    animation-delay: 1.5s;
  }

  .about-hero__float-card--left {
    bottom: 30%;
    right: -5%;
    animation-delay: 0.8s;
  }

  @keyframes floatStat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  /* Wave */
  .about-hero__wave {
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    z-index: 2;
    line-height: 0;
  }

  .about-hero__wave svg {
    width: 100%;
    height: 80px;
    display: block;
  }

  /* Bubbles */
  .about-hero__bubbles {
    position: absolute;
    inset: 0;
    z-index: 1;
    overflow: hidden;
    pointer-events: none;
  }

  .about-hero__bubbles .bubble {
    position: absolute;
    border-radius: 50%;
    background: rgba(0, 180, 216, 0.08);
    animation: bubbleFloat linear infinite;
  }

  .bubble--1 { width: 20px; height: 20px; left: 10%; animation-duration: 8s; animation-delay: 0s; bottom: -20px; }
  .bubble--2 { width: 35px; height: 35px; left: 25%; animation-duration: 12s; animation-delay: 2s; bottom: -35px; }
  .bubble--3 { width: 15px; height: 15px; left: 45%; animation-duration: 7s; animation-delay: 4s; bottom: -15px; }
  .bubble--4 { width: 25px; height: 25px; left: 65%; animation-duration: 10s; animation-delay: 1s; bottom: -25px; }
  .bubble--5 { width: 40px; height: 40px; left: 80%; animation-duration: 14s; animation-delay: 3s; bottom: -40px; }
  .bubble--6 { width: 18px; height: 18px; left: 92%; animation-duration: 9s; animation-delay: 5s; bottom: -18px; }
  .bubble--7 { width: 12px; height: 12px; left: 55%; animation-duration: 6s; animation-delay: 1.5s; bottom: -12px; }
  .bubble--8 { width: 28px; height: 28px; left: 35%; animation-duration: 11s; animation-delay: 3.5s; bottom: -28px; }

  @keyframes bubbleFloat {
    0% { transform: translateY(0) scale(1); opacity: 0; }
    10% { opacity: 0.6; }
    90% { opacity: 0.15; }
    100% { transform: translateY(-100vh) scale(0.5); opacity: 0; }
  }

  /* --- GRID LAYOUT & SIDEBAR --- */
  .about-layout-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  .about-sidebar {
    position: sticky;
    top: calc(var(--header-height) + var(--space-8));
    z-index: 10;
  }

  /* --- TOC (ACCORDION ON MOBILE, STICKY ON DESKTOP) --- */
  .about-toc {
    background: var(--color-bg-card);
    border: 1px solid rgba(0, 67, 112, 0.08);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
  }

  .about-toc-details summary {
    list-style: none;
  }
  .about-toc-details summary::-webkit-details-marker {
    display: none;
  }

  .about-toc-summary {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    cursor: pointer;
  }

  .about-toc__icon {
    font-size: var(--text-xl);
  }

  .about-toc__title {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-dark);
    margin: 0;
  }

  .about-toc-chevron {
    margin-left: auto;
    display: none;
    color: var(--color-text-light);
    transition: transform var(--transition-base);
  }

  .about-toc-details[open] .about-toc-chevron {
    transform: rotate(180deg);
  }

  .about-toc__list {
    list-style: none;
    counter-reset: toc;
    padding: 0;
    margin: var(--space-4) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .about-toc__list li {
    counter-increment: toc;
  }

  .about-toc__list li a {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-2) var(--space-3);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .about-toc__list li a::before {
    content: counter(toc);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: linear-gradient(135deg, rgba(0,119,182,0.08), rgba(0,180,216,0.08));
    color: var(--color-primary);
    font-size: var(--text-xs);
    font-weight: 700;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .about-toc__list li a:hover {
    background: rgba(0, 119, 182, 0.05);
    color: var(--color-primary);
    transform: translateX(4px);
  }

  /* --- HISTORY & COMPANY STRUCTURE --- */
  .about-history {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about-history__text p {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  .about-company-card {
    max-width: 580px;
    margin: var(--space-6) auto;
    padding: var(--space-6) var(--space-8);
    background: linear-gradient(135deg, #ffffff 0%, #f5f8fa 100%);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0, 67, 112, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    transition: all var(--transition-base);
  }

  .about-company-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
    border-color: var(--color-primary);
  }

  .about-company-card__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    flex: 1;
    min-width: 140px;
  }

  .about-company-card__item img {
    height: 50px;
    width: auto;
    object-fit: contain;
  }

  .about-company-card__item span {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    font-weight: 700;
    text-align: center;
    line-height: 1.4;
  }

  .about-company-card__arrow {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-accent);
  }

  .about-company-card__arrow span {
    font-size: 9px;
    text-transform: uppercase;
    font-weight: 800;
    letter-spacing: 0.1em;
  }

  /* Quote */
  .about-quote {
    max-width: 100%;
    margin: var(--space-8) 0;
    padding: var(--space-6) var(--space-8);
    background: linear-gradient(135deg, rgba(0, 67, 112, 0.03), rgba(0, 180, 216, 0.03));
    border-left: 4px solid var(--color-accent);
    border-radius: 0 var(--radius-xl) var(--radius-xl) 0;
    position: relative;
  }

  .about-quote__mark {
    position: absolute;
    top: -10px;
    left: var(--space-4);
    font-size: 4rem;
    font-family: Georgia, serif;
    color: var(--color-accent);
    opacity: 0.15;
    line-height: 1;
    pointer-events: none;
  }

  .about-quote__text {
    font-size: var(--text-base);
    font-style: italic;
    color: var(--color-dark);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
    position: relative;
    z-index: 1;
  }

  .about-quote__author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .about-quote__author img {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--color-accent);
  }

  .about-quote__author strong {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-dark);
  }

  .about-quote__author span {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  /* --- MISSION / VISION --- */
  .about-mission-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
  }

  .about-mission-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0, 67, 112, 0.08);
    transition: all var(--transition-base);
    position: relative;
    overflow: hidden;
  }

  .about-mission-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 4px;
  }

  .about-mission-card--mission::before {
    background: var(--gradient-primary);
  }

  .about-mission-card--vision::before {
    background: var(--gradient-coral);
  }

  .about-mission-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .about-mission-card__icon {
    margin-bottom: var(--space-4);
    color: var(--color-primary);
  }

  .about-mission-card h3 {
    font-size: var(--text-xl);
    font-weight: 800;
    color: var(--color-dark);
    margin-bottom: var(--space-3);
  }

  .about-mission-card p {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }

  .about-mission-list {
    list-style: none;
    padding: 0;
    margin: var(--space-4) 0 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .about-mission-list li {
    display: flex;
    gap: var(--space-2);
    align-items: flex-start;
  }

  .about-mission-list__icon {
    font-size: var(--text-base);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .about-mission-list li div {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .about-mission-stat-highlight {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4);
    background: linear-gradient(135deg, rgba(255,145,0,0.06), rgba(255,138,92,0.06));
    border: 1px solid rgba(255,145,0,0.12);
    border-radius: var(--radius-lg);
    margin-top: var(--space-4);
  }

  .about-mission-stat-highlight__number {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: var(--color-accent);
    line-height: 1;
    flex-shrink: 0;
  }

  .about-mission-stat-highlight__text {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.4;
  }

  /* --- FOUNDER --- */
  .about-founder {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-8);
    align-items: start;
    margin-bottom: var(--space-6);
  }

  .about-founder__media {
    width: 100%;
    text-align: center;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    border: 3px solid rgba(0, 67, 112, 0.08);
    transition: all var(--transition-base);
  }

  .about-founder__media:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .about-founder__caption {
    padding: var(--space-2) 0;
    font-size: var(--text-xs);
    color: var(--color-text-light);
    font-style: italic;
    background: var(--color-bg-alt);
    margin: 0;
  }

  .about-founder__content {
    display: flex;
    flex-direction: column;
  }

  .about-founder__intro p {
    margin-bottom: var(--space-3);
    line-height: var(--leading-relaxed);
    font-size: var(--text-base);
    color: var(--color-text-secondary);
  }

  .about-founder__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .about-founder__tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-1) var(--space-3);
    background: linear-gradient(135deg, rgba(0,119,182,0.06), rgba(0,180,216,0.06));
    color: var(--color-primary-container);
    font-size: var(--text-xs);
    font-weight: 700;
    border-radius: var(--radius-full);
    border: 1px solid rgba(0,119,182,0.1);
  }

  .about-founder-details p {
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .about-founder-details h4 {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    color: var(--color-dark);
    font-weight: 800;
    font-size: var(--text-lg);
  }

  /* Philosophy Cards */
  .about-philosophy-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    margin: var(--space-8) 0;
  }

  .about-philosophy-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0, 67, 112, 0.08);
    transition: all var(--transition-base);
    position: relative;
  }

  .about-philosophy-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-accent);
  }

  .about-philosophy-card__number {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    font-weight: 900;
    color: rgba(255, 145, 0, 0.15);
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .about-philosophy-card h5 {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: var(--space-2);
  }

  .about-philosophy-card p {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  /* --- TEAM STANDARDS --- */
  .about-team-hero {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    border: 1px solid rgba(0, 67, 112, 0.08);
    margin-bottom: var(--space-8);
  }

  .about-team-hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  .about-team-intro p {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .about-standards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .about-standard-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(0, 67, 112, 0.06);
    text-align: center;
    transition: all var(--transition-base);
  }

  .about-standard-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .about-standard-card__icon {
    font-size: 2rem;
    margin-bottom: var(--space-2);
  }

  .about-standard-card h4 {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: var(--space-2);
  }

  .about-standard-card p {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .about-training-section h3 {
    font-size: var(--text-lg);
    font-weight: 800;
    margin-bottom: var(--space-3);
    color: var(--color-dark);
  }

  .about-training-section p {
    font-size: var(--text-sm);
    line-height: 1.6;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
  }

  /* --- CALLOUT --- */
  .about-callout {
    padding: var(--space-5) var(--space-6);
    border-radius: var(--radius-lg);
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
    margin: var(--space-6) 0;
  }

  .about-callout--tip {
    background: rgba(20, 86, 59, 0.04);
    border: 1px solid rgba(20, 86, 59, 0.12);
  }

  .about-callout--important {
    background: rgba(0, 67, 112, 0.03);
    border: 1px solid rgba(0, 67, 112, 0.1);
  }

  .about-callout__icon {
    font-size: 1.3rem;
    flex-shrink: 0;
    margin-top: 1px;
  }

  .about-callout div {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* --- ACHIEVEMENTS --- */
  .about-achievements {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about-achievement {
    display: flex;
    gap: var(--space-6);
    align-items: flex-start;
    background: var(--color-bg-card);
    border-radius: var(--radius-xl);
    padding: var(--space-6);
    border: 1px solid rgba(0, 67, 112, 0.06);
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
  }

  .about-achievement:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }

  .about-achievement__icon-wrap {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, rgba(0,67,112,0.08), rgba(0,180,216,0.08));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .about-achievement__icon-wrap--accent {
    background: linear-gradient(135deg, rgba(255,145,0,0.08), rgba(255,183,3,0.08));
    color: var(--color-accent);
  }

  .about-achievement__icon-wrap--success {
    background: linear-gradient(135deg, rgba(20,86,59,0.08), rgba(52,211,153,0.08));
    color: var(--color-success);
  }

  .about-achievement__content h3 {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-dark);
    margin-bottom: var(--space-2);
  }

  .about-achievement__content p {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
  }

  .about-achievement--full {
    flex-direction: column;
    padding: 0;
    overflow: hidden;
  }

  .about-achievement--full .about-achievement__content {
    padding: var(--space-6) var(--space-8);
  }

  .about-achievement__image-wrapper {
    width: 100%;
    overflow: hidden;
  }

