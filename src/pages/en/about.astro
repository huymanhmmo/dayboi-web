---
import PageLayout from '../../layouts/PageLayout.astro';
import YouTubeVideo from '../../components/YouTubeVideo.astro';

const title = 'About Swim For Life Vietnam: Leading Professional Swimming School';
const description = 'Learn about Swim For Life Vietnam - Our history, mission of popularizing swimming, team of professional coaches, and quality commitments.';

const breadcrumbs = [
  { label: 'Home', href: '/en/' },
  { label: 'About Us' }
];

const faqData = [
  {
    question: 'When did Swim For Life start operating?',
    answer: 'Swim For Life was established and has been operating for more than 10 years, starting from a group of coaches passionate about swimming with the mission of popularizing swimming skills for Vietnamese people, especially children. Over a decade of development, we have become one of the leading prestigious swimming schools in Vietnam.'
  },
  {
    question: 'How many coaches does Swim For Life have?',
    answer: 'Swim For Life currently has a team of dozens of professional coaches operating in Hanoi and Ho Chi Minh City. All coaches graduated from Pedagogical Universities or Universities of Sports and Physical Education, holding professional swimming coach certificates, first-aid certificates, and pedagogical psychology training.'
  },
  {
    question: 'Is Swim For Life an official partner of Vinhomes?',
    answer: 'Yes! Swim For Life is an official partner of Vinhomes in the free swimming lesson program for residents. We are present at many Vinhomes urban areas such as Times City, Ocean Park, Smart City, Grand Park and have successfully organized the Ocean City Swimmer Championship.'
  },
  {
    question: 'What is Swim For Life\'s teaching philosophy?',
    answer: 'Swim For Life pursues a "student-centric" philosophy. We believe that everyone is capable of learning how to swim; the key is method and patience. Our coaches do not just teach techniques but also help students overcome their fear of water, build confidence, and foster a love for aquatic activities.'
  },
  {
    question: 'Does Swim For Life issue course completion certificates?',
    answer: 'Yes! After completing the course and reaching skill standards, students will be issued a Certificate of Swimming Course Completion, verifying that their swimming skills meet safety standards. This certificate is valid for water-related sports and activities.'
  },
  {
    question: 'How to contact Swim For Life?',
    answer: 'You can contact Swim For Life via Hotline: 0979.121.097, email dayboivip@gmail.com, or register online on our website. We operate from 6:00 to 21:00 daily, including Saturdays and Sundays.'
  }
];

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": title,
  "description": description,
  "url": "https://dayboi.vip/en/about/",
  "mainEntity": {
    "@type": "LocalBusiness",
    "@id": "https://dayboi.vip/en/#organization",
    "name": "Swim For Life Vietnam Swimming Center",
    "founder": {
      "@type": "Person",
      "name": "Nguyen Huy Manh",
      "jobTitle": "Director",
      "alumniOf": {
        "@type": "EducationalOrganization",
        "name": "Hanoi National University of Education"
      }
    }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqData.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<PageLayout
  title={title}
  description={description}
  canonical="https://dayboi.vip/en/about/"
  breadcrumbs={breadcrumbs}
  schema={aboutSchema}
  lang="en"
  alternateUrl="/gioi-thieu/"
  alternateLang="vi"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ============ HERO SECTION — PREMIUM SPLIT SCREEN ============ -->
  <section class="about-hero">
    <div class="about-hero__bg">
      <div class="about-hero__bg-gradient"></div>
      <div class="about-hero__bubbles" aria-hidden="true">
        <span class="bubble bubble--1"></span>
        <span class="bubble bubble--2"></span>
        <span class="bubble bubble--3"></span>
        <span class="bubble bubble--4"></span>
        <span class="bubble bubble--5"></span>
        <span class="bubble bubble--6"></span>
        <span class="bubble bubble--7"></span>
        <span class="bubble bubble--8"></span>
      </div>
    </div>
    <div class="container about-hero__grid">
      <div class="about-hero__text">
        <div class="about-hero__badge anim-fade-in">
          <span class="about-hero__badge-dot"></span>
          Over 10 Years of Professional Swim Coaching
        </div>
        <h1 class="about-hero__title anim-fade-in anim-delay-1">
          About <span class="about-hero__highlight">Swim For Life</span> Vietnam
        </h1>
        <p class="about-hero__subtitle anim-fade-in anim-delay-2">
          We don't just teach swimming — we equip over <strong>10,000 students</strong> across Vietnam with vital survival skills and a lifelong passion for aquatic sports.
        </p>

        <!-- Animated Stats -->
        <div class="about-hero__stats anim-fade-in anim-delay-3">
          <div class="about-hero__stat">
            <span class="about-hero__stat-number" data-count="10000">0</span>
            <span class="about-hero__stat-suffix">+</span>
            <span class="about-hero__stat-label">Students</span>
          </div>
          <div class="about-hero__stat-divider"></div>
          <div class="about-hero__stat">
            <span class="about-hero__stat-number" data-count="10">0</span>
            <span class="about-hero__stat-suffix">years+</span>
            <span class="about-hero__stat-label">Experience</span>
          </div>
          <div class="about-hero__stat-divider"></div>
          <div class="about-hero__stat">
            <span class="about-hero__stat-number" data-count="50">0</span>
            <span class="about-hero__stat-suffix">+</span>
            <span class="about-hero__stat-label">Linked Pools</span>
          </div>
        </div>
      </div>
      
      <div class="about-hero__visual anim-fade-in anim-delay-2">
        <div class="about-hero__water-bubbles" aria-hidden="true">
          <span class="water-bubble wb--1"></span>
          <span class="water-bubble wb--2"></span>
          <span class="water-bubble wb--3"></span>
          <span class="water-bubble wb--4"></span>
          <span class="water-bubble wb--5"></span>
          <span class="water-bubble wb--6"></span>
          <span class="water-bubble wb--7"></span>
          <span class="water-bubble wb--8"></span>
          <span class="water-bubble wb--9"></span>
          <span class="water-bubble wb--10"></span>
        </div>
        <div class="about-hero__collage">
          <div class="about-hero__photo about-hero__photo--main">
            <img src="/images/classes/lop-hoc-boi-tre-em-bai-ban-chuyen-nghiep.jpg" alt="Structured swim class for kids" loading="eager" fetchpriority="high" />
          </div>
          <div class="about-hero__photo about-hero__photo--top">
            <img src="/images/coaches/giao-vien-chinh-sua-ky-thuat.jpg" alt="Coach correcting swimming technique" loading="eager" />
          </div>
          <div class="about-hero__photo about-hero__photo--bottom">
            <img src="/images/events/giai-boi-kinh-ngu-ocean-city-2023.jpg" alt="Ocean City Swim Tournament" loading="eager" />
          </div>
        </div>
        <div class="about-hero__float-card about-hero__float-card--top">
          <span class="about-hero__float-icon">🏆</span>
          <div><strong>10+ Years</strong><span>experience</span></div>
        </div>
        <div class="about-hero__float-card about-hero__float-card--bottom">
          <span class="about-hero__float-icon">🎯</span>
          <div><strong>100%</strong><span>result guarantee</span></div>
        </div>
        <div class="about-hero__float-card about-hero__float-card--left">
          <span class="about-hero__float-icon">📍</span>
          <div><strong>2 Cities</strong><span>Hanoi & HCMC</span></div>
        </div>
      </div>
    </div>
    <!-- Wave -->
    <div class="about-hero__wave">
      <svg viewBox="0 0 1440 120" preserveAspectRatio="none">
        <path d="M0,80 C360,120 720,40 1080,80 C1260,100 1380,60 1440,80 L1440,120 L0,120 Z" fill="var(--color-bg)"/>
      </svg>
    </div>
  </section>

  <!-- ============ MAIN CONTENT & GRID ============ -->
  <section class="about-main-wrapper">
    <div class="container about-layout-container">
      <div class="about-layout-grid">
        <!-- Left: Sticky TOC -->
        <aside class="about-sidebar">
          <nav class="about-toc reveal">
            <details class="about-toc-details" open>
              <summary class="about-toc-summary">
                <span class="about-toc__icon">📑</span>
                <h2 class="about-toc__title">Table of Contents</h2>
                <span class="about-toc-chevron">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </summary>
              <ol class="about-toc__list">
                <li><a href="#lich-su-hinh-thanh">The History of Swim For Life</a></li>
                <li><a href="#su-menh-tam-nhin">Mission & Vision</a></li>
                <li><a href="#giam-doc">Director Nguyen Huy Manh</a></li>
                <li><a href="#doi-ngu-hlv">Our Coaching Team</a></li>
                <li><a href="#thanh-tuu">Key Achievements</a></li>
                <li><a href="#doi-tac">Our Partners</a></li>
                <li><a href="#chung-chi-giay-phep">Certificates & Licensing</a></li>
                <li><a href="#cam-ket-chat-luong">Quality Commitments</a></li>
                <li><a href="#cam-nhan-hoc-vien">Student Testimonials</a></li>
                <li><a href="#faq-gioi-thieu">Frequently Asked Questions</a></li>
              </ol>
            </details>
          </nav>
        </aside>

        <!-- Right: Main Content Column -->
        <main class="about-main-content">
          <!-- HISTORY SECTION -->
          <section class="about-section" id="lich-su-hinh-thanh">
            <div class="container">
              <div class="about-section-header reveal">
                <span class="about-section-badge">🏛️ History</span>
                <h2 class="about-section-title">The Story and Development of Swim For Life Vietnam</h2>
              </div>

              <div class="about-history reveal">
                <div class="about-history__text">
                  <p>
                    <strong>Swim For Life Vietnam Swimming Center</strong> was born from a burning passion for swimming and deep concern over the high rate of child drowning in Vietnam. According to World Health Organization (WHO) statistics, Vietnam has one of the highest child drowning rates in Southeast Asia, with thousands of tragic cases occurring annually. Driven by the desire to make a difference, Coach <strong>Nguyen Huy Manh</strong> — the founder of Swim For Life — set out to build a professional swimming school with the mission of popularizing swimming skills for Vietnamese people.
                  </p>

                  <p>
                    Starting as a small group of dedicated coaches, Swim For Life gradually grew, expanding from a dozen initial students to thousands of graduates each year. Through more than <strong>10 years</strong> of continuous development, Swim For Life has established itself as one of the leading prestigious swimming schools in Vietnam, operating in two major cities: <a href="/en/contact/">Hanoi and Ho Chi Minh City</a>.
                  </p>

                  <p>
                    Swim For Life operates officially under <strong>Your Dreams Joint Stock Company</strong> (Tax code: 0108879900), an enterprise legally established under Vietnamese law. With a solid legal foundation, professional management, and structured training programs, Swim For Life has steadily become a trusted brand chosen by thousands of families nationwide.
                  </p>
                </div>

                <!-- Company Structure Card -->
                <div class="about-company-card reveal">
                  <div class="about-company-card__item">
                    <img src="/images/logo/swim-for-life-logo.png" alt="Swim For Life Vietnam Logo" loading="lazy" />
                    <span>Swim For Life<br/>Swim Center</span>
                  </div>
                  <div class="about-company-card__arrow">
                    <span>Subsidiary of</span>
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </div>
                  <div class="about-company-card__item">
                    <img src="/images/logo/your-dreams-logo.png" alt="Your Dreams Joint Stock Company Logo" loading="lazy" />
                    <span>Your Dreams<br/>Joint Stock Co.</span>
                  </div>
                </div>

                <div class="about-history__text reveal">
                  <p>
                    One of the key milestones in Swim For Life's journey is becoming an <strong>official partner of Vinhomes</strong> — Vietnam's leading real estate group. This partnership not only validates the reputation of Swim For Life but also opens up opportunities for thousands of Vinhomes residents to access high-quality, completely free swimming programs. From Vinhomes Times City and Ocean Park to Smart City, Swim For Life has successfully operated in major urban areas, bringing safe swimming skills to residents.
                  </p>
                </div>

                <blockquote class="about-quote reveal">
                  <div class="about-quote__mark">"</div>
                  <p class="about-quote__text">
                    We started with a simple dream: that every child in Vietnam knows how to swim and has the skills to survive in water. And after more than 10 years, that dream is gradually becoming a reality.
                  </p>
                  <footer class="about-quote__author">
                    <img src="/images/team/thay-nguyen-huy-manh.png" alt="Coach Nguyen Huy Manh" loading="lazy" />
                    <div>
                      <strong>Coach Nguyen Huy Manh</strong>
                      <span>Director of Swim For Life Vietnam</span>
                    </div>
                  </footer>
                </blockquote>
              </div>
            </div>
          </section>

  <!-- ============ SỨ MỆNH & TẦM NHÌN ============ -->
  <section class="about-section about-section--alt" id="su-menh-tam-nhin">
    <div class="container">
      <div class="about-section-header reveal">
        <span class="about-section-badge">🎯 Sứ Mệnh</span>
        <h2 class="about-section-title">Our Mission & Vision</h2>
      </div>

      <div class="about-mission-grid reveal">
        <!-- Mission Card -->
        <div class="about-mission-card about-mission-card--mission">
          <div class="about-mission-card__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="2"/><path d="M24 14v10l7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="24" cy="24" r="4" fill="currentColor" opacity="0.3"/></svg>
          </div>
          <h3>Mission</h3>
          <p>
            Our mission is to <strong>popularize swimming skills and prevent water drowning</strong> for all ages, especially children in Vietnam. We believe that swimming is not just a sport, but a <strong>vital survival skill</strong> that everyone must be equipped with from an early age.
          </p>
          <ul class="about-mission-list">
            <li>
              <span class="about-mission-list__icon">🏊</span>
              <div><strong>Water Survival Skills:</strong> Learn to swim, tread water, and rescue oneself in emergency situations.</div>
            </li>
            <li>
              <span class="about-mission-list__icon">💪</span>
              <div><strong>Health & Fitness:</strong> Develop muscle strength, enhance cardiovascular systems, and improve overall respiratory health.</div>
            </li>
            <li>
              <span class="about-mission-list__icon">⭐</span>
              <div><strong>Confidence Building:</strong> Help <a href="/en/courses/">children</a> overcome their fear of water and build mental resilience.</div>
            </li>
            <li>
              <span class="about-mission-list__icon">❤️</span>
              <div><strong>Healthy Habits:</strong> Cultivate an active lifestyle and improve overall quality of life.</div>
            </li>
          </ul>
        </div>

        <!-- Vision Card -->
        <div class="about-mission-card about-mission-card--vision">
          <div class="about-mission-card__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><path d="M4 24s7-14 20-14 20 14 20 14-7 14-20 14S4 24 4 24z" stroke="currentColor" stroke-width="2"/><circle cx="24" cy="24" r="7" stroke="currentColor" stroke-width="2"/><circle cx="24" cy="24" r="3" fill="currentColor" opacity="0.3"/></svg>
          </div>
          <h3>Vision</h3>
          <p>
            Swim For Life aims to become the <strong>leading swimming training provider in Vietnam</strong>, expanding our network nationwide. We want every family to realize the importance of swimming skills, and every child to learn swimming properly, safely, and systematically.
          </p>
          <p>
            In the long term, Swim For Life is committed to building a comprehensive aquatic ecosystem, including training amateur athletes, organizing community swimming tournaments, and cooperating with social organizations to combat drowning on a national scale.
          </p>
          <div class="about-mission-stat-highlight">
            <span class="about-mission-stat-highlight__number">88%</span>
            <span class="about-mission-stat-highlight__text">reduction in drowning risk when children learn water safety early <em>(Source: UNICEF)</em></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ GIÁM ĐỐC ============ -->
  <section class="about-section" id="giam-doc">
    <div class="container">
      <div class="about-section-header reveal">
        <span class="about-section-badge">👤 Founder</span>
        <h2 class="about-section-title">Director Nguyen Huy Manh - The Founder of Swim For Life</h2>
      </div>

      <div class="about-founder reveal">
        <div class="about-founder__media">
          <YouTubeVideo
            videoId="b4B7GfHEsuk"
            poster="/images/team/thay-nguyen-huy-manh-2.png"
            alt="Coach Nguyen Huy Manh - Founder and Director of Swim For Life Vietnam, graduated from Hanoi National University of Education"
            width={400}
            height={500}
          />
          <p class="about-founder__caption">
            Coach Nguyen Huy Manh — Founder of Swim For Life
          </p>
        </div>

        <div class="about-founder__content">
          <div class="about-founder__intro">
            <p>
              <strong>Coach Nguyen Huy Manh</strong> is the founder and Managing Director of Swim For Life Vietnam. Graduating from <strong>Hanoi National University of Education</strong> — the leading pedagogical institution in Vietnam — Coach Manh possesses a solid educational foundation and a scientific, highly effective teaching approach.
            </p>
            <p>
              With over <strong>12 years of experience</strong> in swim coaching, Coach Manh has directly trained and supervised thousands of students of all ages. He is well-known for his patience, dedication, and placing student safety and progress above all else.
            </p>
            <ul style="display: flex; flex-direction: column; gap: var(--space-2); font-size: var(--text-sm); line-height: 1.6; color: var(--color-text-secondary); margin-bottom: var(--space-6); list-style-type: none; padding-left: 0; margin-top: var(--space-4);">
              <li style="display: flex; gap: var(--space-2); align-items: flex-start;">
                <span style="color: var(--color-accent); font-weight: bold;">✓</span>
                <span><strong>Director of Swim For Life Vietnam Professional Swimming Center</strong></span>
              </li>
              <li style="display: flex; gap: var(--space-2); align-items: flex-start;">
                <span style="color: var(--color-accent); font-weight: bold;">✓</span>
                <span><strong>Head of Vinhomes Free Swimming Campaign:</strong> Providing water safety training to kids in Vinhomes urban areas since 2018 (teaching 2,000 - 3,000 students/year).</span>
              </li>
              <li style="display: flex; gap: var(--space-2); align-items: flex-start;">
                <span style="color: var(--color-accent); font-weight: bold;">✓</span>
                <span><strong>Managing & Training 100+ Staff</strong> of professional swim coaches and lifeguards.</span>
              </li>
            </ul>
          </div>

          <!-- Founder Tags -->
          <div class="about-founder__tags">
            <span class="about-founder__tag">🎓 Hanoi Nat. Univ. of Education</span>
            <span class="about-founder__tag">🏊 12+ Years Experience</span>
            <span class="about-founder__tag">👨‍🏫 10,000+ Students</span>
            <span class="about-founder__tag">🤝 Vinhomes Partner</span>
          </div>
        </div>
      </div>

      <div class="about-founder-details reveal">
        <p>
          Coach Manh's journey with swimming began with a childhood love for aquatic sports. After graduating from University, he realized that many families did not fully recognize the importance of teaching water safety to their children. Many children, especially in rural areas, had no access to structured swimming lessons, leading to tragic water accidents.
        </p>

        <p>
          Driven by the desire to change this, Coach Manh gathered like-minded colleagues to found Swim For Life with the motto: <strong>"Every student is a unique individual who deserves personal care and the most suitable teaching method."</strong> This philosophy serves as the guiding light for all Swim For Life operations, from designing course curriculums to selecting and training coaches.
        </p>

        <!-- Teaching Philosophy Cards -->
        <h4>Teaching Philosophy of Coach Nguyen Huy Manh</h4>
        <p>
          Unlike many centers that focus solely on technique, Coach Manh built Swim For Life on a foundation of comprehensive education. According to him, an effective swimming lesson must harmoniously combine three factors: <strong>swimming technique, pedagogical psychology, and survival skills</strong>.
        </p>

        <div class="about-philosophy-grid">
          <div class="about-philosophy-card reveal">
            <div class="about-philosophy-card__number">01</div>
            <h5>Swimming Technique</h5>
            <p>Coaches must teach correct techniques from the start, never rushing progress at the expense of important details. Each movement must be precise and rhythmic before moving to the next level.</p>
          </div>
          <div class="about-philosophy-card reveal">
            <div class="about-philosophy-card__number">02</div>
            <h5>Pedagogical Psychology</h5>
            <p>Recognizing that fear of water is the biggest obstacle, we specialize in mental coaching. Each instructor is a supportive friend who knows how to encourage students.</p>
          </div>
          <div class="about-philosophy-card reveal">
            <div class="about-philosophy-card__number">03</div>
            <h5>Survival Skills</h5>
            <p>Besides the 4 core strokes (<a href="/en/swimming-techniques/">breaststroke</a>, <a href="/en/swimming-techniques/">freestyle</a>, <a href="/en/swimming-techniques/">backstroke</a>, <a href="/en/swimming-techniques/">butterfly</a>), we emphasize treading water — the most vital skill to stay alive in deep water.</p>
          </div>
        </div>

        <p>
          Under the leadership of Coach Manh, Swim For Life has made a strong impact on swimming education in Vietnam. Training over 10,000 successful students, establishing strategic partnerships with Vinhomes, and organizing the Ocean City Swimmer Championship are all testaments to the vision and dedication of the founder.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ ĐỘI NGŨ HLV ============ -->
  <section class="about-section about-section--alt" id="doi-ngu-hlv">
    <div class="container">
      <div class="about-section-header reveal">
        <span class="about-section-badge">👨‍🏫 Team</span>
        <h2 class="about-section-title">Our Team of Professional Swimming Coaches</h2>
      </div>

      <div class="about-team-hero reveal">
        <img
          src="/images/classes/giao-vien-ho-tro-tan-tam.jpg"
          alt="Dedicated swim coaching team from Swim For Life supporting students in the pool"
          width="800"
          height="450"
          loading="lazy"
        />
      </div>

      <div class="about-team-intro reveal">
        <p>
          Our coaches are Swim For Life's most valuable asset. We understand that teaching quality depends entirely on the capability and dedication of the instructors. Therefore, Swim For Life applies an extremely strict selection and training process to ensure each coach meets the highest standards.
        </p>
      </div>

      <!-- Standards Grid -->
      <h3 class="reveal" style="margin-bottom: var(--space-8); text-align: center; color: var(--color-dark);">Coach Selection Standards at Swim For Life</h3>
      <p class="reveal" style="text-align: center; max-width: 700px; margin: 0 auto var(--space-10); color: var(--color-text-secondary);">
        Every applicant wishing to join Swim For Life as a coach must meet all of the following requirements. Our multi-stage evaluation process ensures only the most qualified and passionate candidates join our team:
      </p>

      <div class="about-standards-grid">
        <div class="about-standard-card reveal">
          <div class="about-standard-card__icon">🎓</div>
          <h4>Professional Qualification</h4>
          <p>Graduated from Pedagogical or Sports Universities. Certified by authorized sports agencies.</p>
        </div>
        <div class="about-standard-card reveal">
          <div class="about-standard-card__icon">🏥</div>
          <h4>First Aid Certification</h4>
          <p>Certified in First Aid and CPR, ensuring quick response in emergency situations. Mandatory for 100% of coaches.</p>
        </div>
        <div class="about-standard-card reveal">
          <div class="about-standard-card__icon">🧠</div>
          <h4>Pedagogical Psychology</h4>
          <p>Trained in educational psychology to connect with children, adults, and those with aquaphobia.</p>
        </div>
        <div class="about-standard-card reveal">
          <div class="about-standard-card__icon">🏊</div>
          <h4>Practical Skills</h4>
          <p>Master all 4 strokes, water treading, and life-saving rescue techniques.</p>
        </div>
        <div class="about-standard-card reveal">
          <div class="about-standard-card__icon">❤️</div>
          <h4>Ethical Standards</h4>
          <p>Dedicated, patient, honest, and highly responsible. Puts student safety above all else.</p>
        </div>
      </div>

      <div class="about-training-section reveal">
        <h3>Internal Training Program</h3>
        <p>
