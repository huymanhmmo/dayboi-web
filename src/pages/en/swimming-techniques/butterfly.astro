const errors = [
  {
    title: 'Bending knees too much (Kicking like breaststroke)',
    problem: 'Drawing knees forward creates enormous frontal drag, sinking the hips and halting forward momentum.',
    solution: 'Focus on initiating the dolphin wave from the chest and hips. Keep knees long and relaxed; let ankles flick the water.'
  },
  {
    title: 'Late breathing (Breathing during recovery)',
    problem: 'Trying to breathe when arms are recovering over the water drops the chest, stops momentum, and leads to swallowing water.',
    solution: 'Lift your chin to breathe early—during the inward sweep and push phase. Head must submerge before arms enter.'
  },
  {
    title: 'Stiff shoulders during arm recovery',
    problem: 'Tensing shoulders and arms during recovery creates high fatigue and strains the rotator cuff.',
    solution: 'Relax wrists and shoulders. Use the momentum of the push phase to swing arms wide and low over the water.'
  },
  {
    title: 'Missing the second dolphin kick',
    problem: 'Kicking only once per cycle causes the hips to sink during the push phase, making arm recovery extremely heavy.',
    solution: 'Perform the second downward kick exactly as hands finish pushing past the hips. This lifts the upper body naturally.'
  }
