const errors = [
  {
    title: 'Bicycle Kicking (Kicking straight back)',
    problem: 'Pushing legs straight back without wrapping or flexing ankles outward, resulting in zero forward thrust.',
    solution: 'Practice on land. Focus on drawing a circular arc: draw heels in → flex toes out → whip back → squeeze legs together.'
  },
  {
    title: 'Pointed toes during whip kick',
    problem: 'Keeping toes pointed while kicking, slicing the water rather than pushing it backward.',
    solution: 'Flex your ankles outward at 90 degrees during the draw phase. Think of using the soles of your feet to push the water.'
