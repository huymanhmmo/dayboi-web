---
/**
 * index.astro — Trang chủ Swim For Life Việt Nam
 * SEO Target: dạy bơi, học bơi, khóa học bơi, trung tâm dạy bơi
 */
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import CoachesSection from '../components/CoachesSection.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Swim For Life Việt Nam",
  "alternateName": "Trung tâm dạy bơi Swim For Life",
  "description": "Trung tâm dạy bơi chuyên nghiệp hàng đầu Việt Nam. Đào tạo bơi lội cho mọi lứa tuổi từ trẻ em đến người lớn với đội ngũ HLV giàu kinh nghiệm.",
  "url": "https://dayboi.vip",
  "telephone": "+84979121097",
  "email": "dayboivip@gmail.com",
  "image": "https://dayboi.vip/images/brand/logo.png",
  "priceRange": "Liên hệ nhận báo giá",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "VN",
    "addressLocality": "Hà Nội"
  },
  "sameAs": [
    "http://zalo.me/0979121097"
  ]
};

const regions = [
  {
    name: "Miền Bắc",
    color: "aqua",
    provinces: [
      { name: "Hà Nội", slug: "hoc-boi-ha-noi", isTW: true },
      { name: "Hải Phòng", slug: "hoc-boi-hai-phong", isTW: true },
      { name: "Quảng Ninh", slug: "hoc-boi-quang-ninh" },
      { name: "Bắc Ninh", slug: "hoc-boi-bac-ninh" },
      { name: "Thái Nguyên", slug: "hoc-boi-thai-nguyen" },
      { name: "Phú Thọ", slug: "hoc-boi-phu-tho" },
      { name: "Ninh Bình", slug: "hoc-boi-ninh-binh" },
      { name: "Hưng Yên", slug: "hoc-boi-hung-yen" },
      { name: "Thanh Hóa", slug: "hoc-boi-thanh-hoa" },
      { name: "Lào Cai", slug: "hoc-boi-lao-cai" },
      { name: "Tuyên Quang", slug: "hoc-boi-tuyen-quang" },
      { name: "Lạng Sơn", slug: "hoc-boi-lang-son" },
      { name: "Sơn La", slug: "hoc-boi-son-la" },
      { name: "Điện Biên", slug: "hoc-boi-dien-bien" },
      { name: "Lai Châu", slug: "hoc-boi-lai-chau" },
      { name: "Cao Bằng", slug: "hoc-boi-cao-bang" }
    ]
  },
  {
    name: "Miền Trung",
    color: "teal",
    provinces: [
      { name: "Đà Nẵng", slug: "hoc-boi-da-nang", isTW: true },
      { name: "Huế", slug: "hoc-boi-hue", isTW: true },
      { name: "Khánh Hòa", slug: "hoc-boi-khanh-hoa" },
      { name: "Nghệ An", slug: "hoc-boi-nghe-an" },
      { name: "Bình Định", slug: "hoc-boi-binh-dinh" },
      { name: "Quảng Ngãi", slug: "hoc-boi-quang-ngai" },
      { name: "Quảng Bình", slug: "hoc-boi-quang-binh" },
      { name: "Hà Tĩnh", slug: "hoc-boi-ha-tinh" }
    ]
  },
  {
    name: "Tây Nguyên & Đông Nam Bộ",
    color: "gold",
    provinces: [
      { name: "TP. Hồ Chí Minh", slug: "hoc-boi-tphcm", isTW: true },
      { name: "Đồng Nai", slug: "hoc-boi-dong-nai", isTW: true },
      { name: "Lâm Đồng", slug: "hoc-boi-lam-dong" },
      { name: "Đắk Lắk", slug: "hoc-boi-dak-lak" }
    ]
  },
  {
    name: "Miền Tây Nam Bộ",
    color: "coral",
    provinces: [
      { name: "Cần Thơ", slug: "hoc-boi-can-tho", isTW: true },
      { name: "An Giang", slug: "hoc-boi-an-giang" },
      { name: "Đồng Tháp", slug: "hoc-boi-dong-thap" },
      { name: "Vĩnh Long", slug: "hoc-boi-vinh-long" },
      { name: "Tây Ninh", slug: "hoc-boi-tay-ninh" },
      { name: "Cà Mau", slug: "hoc-boi-ca-mau" }
    ]
  }
];

const allProvinces = regions.flatMap(r => r.provinces);
const sortedLocations = [...allProvinces].sort((a, b) => a.name.localeCompare(b.name, 'vi'));
---

<MainLayout
  title="Trung Tâm Dạy Bơi Chuyên Nghiệp"
  description="Swim For Life Việt Nam — Trung tâm dạy bơi chuyên nghiệp hàng đầu. Khóa học bơi cho trẻ em & người lớn, đội ngũ HLV giàu kinh nghiệm, phương pháp an toàn. Gọi ngay 0979.121.097!"
  lang="vi"
  alternateUrl="/en/"
  schema={schema}
>
  <Header slot="header" lang="vi" currentPath="/" />

  <!-- ============================================
       HERO SECTION — Split Screen Premium
       ============================================ -->
  <section class="hero" id="hero-section">
    <div class="hero__bg">
      <div class="hero__bg-gradient"></div>
      <div class="hero__bubbles" aria-hidden="true">
        <span class="bubble bubble--1"></span>
        <span class="bubble bubble--2"></span>
        <span class="bubble bubble--3"></span>
        <span class="bubble bubble--4"></span>
        <span class="bubble bubble--5"></span>
        <span class="bubble bubble--6"></span>
        <span class="bubble bubble--7"></span>
        <span class="bubble bubble--8"></span>
      </div>
    </div>
    <div class="container hero__grid">
      <div class="hero__text">
        <div class="hero__badge reveal">
          <span class="hero__badge-dot"></span>
          Trung Tâm Dạy Bơi Chuyên Nghiệp #1 Việt Nam
        </div>
        <h1 class="hero__title reveal">
          Học Bơi<br/>
          <span class="hero__title-highlight">An Toàn</span> — Vui Vẻ<br/>
          & <span class="hero__title-accent">Hiệu Quả</span>
        </h1>
        <p class="hero__subtitle reveal">
          Swim For Life Việt Nam — Đào tạo bơi lội cho mọi lứa tuổi với đội ngũ HLV chuyên nghiệp, 
          phương pháp khoa học, và cam kết an toàn tuyệt đối.
        </p>
        <div class="hero__actions reveal">
          <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="btn btn--accent btn--lg btn--pulse">
            💬 Tư Vấn Miễn Phí
          </a>
          <a href="tel:0979121097" class="btn btn--hero-outline btn--lg">
            📞 0979.121.097
          </a>
        </div>
        <div class="hero__trust reveal">
          <div class="hero__trust-avatars">
            <img src="/images/team/thay-nguyen-huy-manh.png" alt="Thầy Nguyễn Huy Mạnh - HLV Swim For Life" class="hero__trust-avatar" />
            <img src="/images/team/thay-vu-van-thinh.jpg" alt="Thầy Vũ Văn Thịnh - HLV Swim For Life" class="hero__trust-avatar" />
            <img src="/images/team/co-le-thi-giang.jpg" alt="Cô Lê Thị Giang - HLV Swim For Life" class="hero__trust-avatar" />
          </div>
          <div class="hero__trust-text">
            <strong>5,000+ học viên</strong> đã biết bơi cùng chúng tôi
          </div>
        </div>
      </div>
      <div class="hero__visual reveal">
        <div class="hero__water-bubbles" aria-hidden="true">
          <span class="water-bubble wb--1"></span>
          <span class="water-bubble wb--2"></span>
          <span class="water-bubble wb--3"></span>
          <span class="water-bubble wb--4"></span>
          <span class="water-bubble wb--5"></span>
          <span class="water-bubble wb--6"></span>
          <span class="water-bubble wb--7"></span>
          <span class="water-bubble wb--8"></span>
          <span class="water-bubble wb--9"></span>
          <span class="water-bubble wb--10"></span>
          <span class="water-bubble wb--11"></span>
          <span class="water-bubble wb--12"></span>
          <span class="water-bubble wb--13"></span>
          <span class="water-bubble wb--14"></span>
          <span class="water-bubble wb--15"></span>
          <span class="water-bubble wb--16"></span>
          <span class="water-bubble wb--17"></span>
          <span class="water-bubble wb--18"></span>
        </div>
        <div class="hero__collage">
          <div class="hero__photo hero__photo--main">
            <img src="/images/classes/lop-hoc-boi-mien-phi-cu-dan-nhi-vinhomes.jpg" alt="Lớp học bơi chuyên nghiệp cho trẻ em tại Swim For Life Việt Nam" loading="eager" fetchpriority="high" />
          </div>
          <div class="hero__photo hero__photo--top">
            <img src="/images/coaches/giao-vien-chinh-sua-ky-thuat.jpg" alt="Giáo viên chỉnh sửa kỹ thuật bơi cho học viên" loading="eager" />
          </div>
          <div class="hero__photo hero__photo--bottom">
            <img src="/images/classes/lop-hoc-boi-tre-em-bai-ban-chuyen-nghiep.jpg" alt="Lớp học bơi trẻ em bài bản chuyên nghiệp" loading="eager" />
          </div>
        </div>
        <div class="hero__float-card hero__float-card--top">
          <span class="hero__float-icon">🏆</span>
          <div><strong>10+ năm</strong><span>kinh nghiệm</span></div>
        </div>
        <div class="hero__float-card hero__float-card--bottom">
          <span class="hero__float-icon">🎯</span>
          <div><strong>100%</strong><span>cam kết biết bơi</span></div>
        </div>
        <div class="hero__float-card hero__float-card--left">
          <span class="hero__float-icon">📍</span>
          <div><strong>34 tỉnh/TP</strong><span>toàn quốc</span></div>
        </div>
      </div>
    </div>
    <div class="hero__wave">
      <svg viewBox="0 0 1440 120" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,80 C360,120 720,40 1080,80 C1260,100 1380,60 1440,80 L1440,120 L0,120 Z" fill="var(--color-bg)"/>
      </svg>
    </div>
  </section>

  <!-- ============================================
       WHY CHOOSE US
       ============================================ -->
  <section class="section why-us" id="why-choose-us">
    <div class="container">
      <div class="section__header text-center reveal">
        <span class="section__badge">Tại Sao Chọn Chúng Tôi?</span>
        <h2 class="section__title">Swim For Life Việt Nam — <span class="text-gradient">Khác Biệt Từ Tâm</span></h2>
        <p class="section__desc">Chúng tôi không chỉ dạy bơi, mà còn truyền cảm hứng và kỹ năng sinh tồn dưới nước cho mọi lứa tuổi.</p>
      </div>
      <div class="why-us__grid">
        <div class="feature-card reveal">
          <div class="feature-card__icon feature-card__icon--aqua">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="feature-card__title">An Toàn Tuyệt Đối</h3>
          <p class="feature-card__desc">Giáo viên luôn đồng hành sát sao, trang bị phao bơi đầy đủ, tuân thủ quy trình an toàn nghiêm ngặt trong mọi buổi học.</p>
        </div>
        <div class="feature-card reveal">
          <div class="feature-card__icon feature-card__icon--coral">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="feature-card__title">HLV Chuyên Nghiệp</h3>
          <p class="feature-card__desc">Đội ngũ huấn luyện viên được đào tạo bài bản, nhiều năm kinh nghiệm, tận tâm và vui vẻ với từng học viên.</p>
        </div>
        <div class="feature-card reveal">
          <div class="feature-card__icon feature-card__icon--teal">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="feature-card__title">Phương Pháp Khoa Học</h3>
          <p class="feature-card__desc">Giáo trình dạy bơi theo chuẩn quốc tế, kết hợp lý thuyết trên cạn và thực hành dưới nước hiệu quả.</p>
        </div>
        <div class="feature-card reveal">
          <div class="feature-card__icon feature-card__icon--gold">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          </div>
          <h3 class="feature-card__title">Cam Kết Kết Quả</h3>
          <p class="feature-card__desc">100% học viên biết bơi sau khóa học. Cấp giấy chứng nhận hoàn thành khóa học bơi chính thức.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       COURSES SECTION
       ============================================ -->
  <section class="section courses-section" id="courses-section">
    <div class="container">
      <div class="section__header text-center reveal">
        <span class="section__badge">Khóa Học Bơi</span>
        <h2 class="section__title">Chọn Khóa Học <span class="text-gradient">Phù Hợp Với Bạn</span></h2>
        <p class="section__desc">Đa dạng khóa học cho mọi lứa tuổi và trình độ — từ bơi cơ bản đến nâng cao.</p>
      </div>
      <div class="courses-grid">
        <!-- Bơi Trẻ Em -->
        <div class="course-card reveal">
          <div class="course-card__img-wrap">
            <img 
              src="/images/classes/lop-hoc-boi-tre-em-bai-ban-chuyen-nghiep.jpg" 
              alt="Lớp học bơi trẻ em được tổ chức giảng dạy bài bản, chuyên nghiệp tại Swim For Life Việt Nam" 
              class="course-card__img" 
              loading="lazy"
            />
            <span class="course-card__badge course-card__badge--hot">Phổ Biến</span>
          </div>
          <div class="course-card__body">
            <h3 class="course-card__title">Khóa Học Bơi Trẻ Em</h3>
            <p class="course-card__desc">Dành cho trẻ từ 4-15 tuổi. Dạy bơi an toàn, vui vẻ, giúp trẻ tự tin dưới nước và nắm vững kỹ năng sinh tồn.</p>
            <ul class="course-card__features">
              <li>✅ Lớp nhỏ 5-8 học viên</li>
              <li>✅ Giáo viên tận tâm, vui vẻ</li>
              <li>✅ Trang bị phao bơi an toàn</li>
            </ul>
            <div class="course-card__footer">
              <span class="course-card__price">Liên hệ nhận báo giá</span>
              <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--sm">Đăng Ký Ngay</a>
            </div>
          </div>
        </div>

        <!-- Bơi Người Lớn -->
        <div class="course-card reveal">
          <div class="course-card__img-wrap">
            <img 
              src="/images/safety/hoc-vien-duoc-huong-dan-trong-nuoc.jpg" 
              alt="Học viên được hướng dẫn chỉnh sửa kỹ thuật tận tình trong quá trình tập luyện bơi" 
              class="course-card__img" 
              loading="lazy"
            />
          </div>
          <div class="course-card__body">
            <h3 class="course-card__title">Khóa Học Bơi Người Lớn</h3>
            <p class="course-card__desc">Dành cho người lớn từ 16 tuổi trở lên. Không bao giờ là quá muộn để học bơi — vượt qua nỗi sợ nước ngay hôm nay!</p>
            <ul class="course-card__features">
              <li>✅ Lớp riêng, không ngại ngùng</li>
              <li>✅ Huấn luyện viên kiên nhẫn</li>
              <li>✅ Linh hoạt thời gian</li>
            </ul>
            <div class="course-card__footer">
              <span class="course-card__price">Liên hệ nhận báo giá</span>
              <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--sm">Đăng Ký Ngay</a>
            </div>
          </div>
        </div>

        <!-- Bơi 1 Kèm 1 -->
        <div class="course-card reveal">
          <div class="course-card__img-wrap">
            <img 
              src="/images/coaches/giao-vien-chinh-sua-ky-thuat.jpg" 
              alt="Giáo viên tận tình chỉnh sửa kỹ thuật bơi cho từng học sinh - dạy bơi 1 kèm 1" 
              class="course-card__img" 
              loading="lazy"
            />
            <span class="course-card__badge course-card__badge--vip">VIP</span>
          </div>
          <div class="course-card__body">
            <h3 class="course-card__title">Dạy Bơi 1 Kèm 1</h3>
            <p class="course-card__desc">Chương trình dạy bơi cá nhân hóa. Giáo viên tập trung 100% vào bạn, tiến bộ nhanh gấp 3 lần lớp nhóm.</p>
            <ul class="course-card__features">
              <li>✅ 1 HLV - 1 học viên</li>
              <li>✅ Giáo trình riêng biệt</li>
              <li>✅ Tiến bộ nhanh nhất</li>
            </ul>
            <div class="course-card__footer">
              <span class="course-card__price">Liên hệ nhận báo giá</span>
              <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="btn btn--accent btn--sm">Đăng Ký Ngay</a>
            </div>
          </div>
        </div>

        <!-- Bơi Cấp Tốc -->
        <div class="course-card reveal">
          <div class="course-card__img-wrap">
            <img 
              src="/images/classes/to-chuc-tap-luyen-bai-ban-chuyen-nghiep.jpg" 
              alt="Tổ chức tập luyện bơi bài bản chuyên nghiệp tại Swim For Life Việt Nam" 
              class="course-card__img" 
              loading="lazy"
            />
            <span class="course-card__badge course-card__badge--fast">Cấp Tốc</span>
          </div>
          <div class="course-card__body">
            <h3 class="course-card__title">Khóa Bơi Cấp Tốc</h3>
            <p class="course-card__desc">Học bơi nhanh trong 7-10 buổi. Phù hợp cho người bận rộn muốn nắm vững kỹ năng bơi cơ bản trong thời gian ngắn.</p>
            <ul class="course-card__features">
              <li>✅ Chỉ 7-10 buổi học</li>
              <li>✅ Cam kết biết bơi</li>
              <li>✅ Lịch học linh hoạt</li>
            </ul>
            <div class="course-card__footer">
              <span class="course-card__price">Liên hệ nhận báo giá</span>
              <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--sm">Đăng Ký Ngay</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       ABOUT / DIRECTOR SECTION
       ============================================ -->
  <section class="section about-section" id="about-director">
    <div class="container">
      <div class="about-grid">
        <div class="about-images reveal">
          <div class="about-img-main">
            <img 
              src="/images/coaches/giam-doc-nguyen-huy-manh-vtc9.png" 
              alt="HLV Nguyễn Huy Mạnh - Giám đốc Trung tâm dạy bơi Swim For Life trả lời phỏng vấn trên kênh VTC9" 
              class="about-img" 
              loading="lazy"
            />
          </div>
          <div class="about-img-secondary">
            <img 
              src="/images/team/thay-nguyen-huy-manh.png" 
              alt="Thầy Nguyễn Huy Mạnh - Giám đốc Trung tâm dạy bơi chuyên nghiệp Swim For Life Việt Nam" 
              class="about-img" 
              loading="lazy"
            />
          </div>
        </div>
        <div class="about-content reveal">
          <span class="section__badge">Về Chúng Tôi</span>
          <h2 class="section__title">Thầy Nguyễn Huy Mạnh<br/><span class="text-gradient">Giám Đốc Swim For Life</span></h2>
          <p class="about-text">
            Với hơn 10 năm kinh nghiệm trong lĩnh vực đào tạo bơi lội, Thầy Nguyễn Huy Mạnh đã xây dựng 
            <strong>Swim For Life Việt Nam</strong> trở thành một trong những trung tâm dạy bơi chuyên nghiệp 
            hàng đầu cả nước.
          </p>
