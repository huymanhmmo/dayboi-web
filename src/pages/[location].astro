---
import PageLayout from '../layouts/PageLayout.astro';
import RegistrationForm from '../components/RegistrationForm.astro';
import CoachesSection from '../components/CoachesSection.astro';
import { locations } from '../data/locations.js';

export function getStaticPaths() {
  return locations.map((loc) => ({
    params: { location: loc.slug },
    props: { loc },
  }));
}

const { loc } = Astro.props;
const currentYear = new Date().getFullYear();

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: `Học bơi ${loc.name}` },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": loc.title,
  "description": loc.description,
  "author": {
    "@type": "Person",
    "name": "Thầy Nguyễn Huy Mạnh",
    "jobTitle": "Giám đốc đào tạo",
    "affiliation": {
      "@type": "Organization",
      "name": "Swim For Life Việt Nam"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Swim For Life Việt Nam",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dayboi.vip/images/brand/logo.png"
    }
  },
  "datePublished": "2026-01-25",
  "dateModified": "2026-06-10",
  "image": `https://dayboi.vip${loc.image}`,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://dayboi.vip/${loc.slug}/`
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": `Trung tâm dạy bơi Swim For Life Việt Nam - ${loc.name}`,
  "description": `Khóa học bơi chuyên nghiệp dạy kèm riêng tại khu vực ${loc.name} và lân cận.`,
  "telephone": "0979121097",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": loc.name,
    "addressCountry": "VN"
  },
  "url": `https://dayboi.vip/${loc.slug}/`,
  "image": `https://dayboi.vip${loc.image}`,
  "priceRange": "Liên hệ nhận báo giá"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": loc.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const combinedSchema = [articleSchema, localBusinessSchema, faqSchema];
---

<PageLayout
  title={`${loc.title} [${currentYear}]`}
  description={loc.description}
  canonical={`https://dayboi.vip/${loc.slug}/`}
  image={loc.image}
  type="article"
  breadcrumbs={breadcrumbs}
  schema={combinedSchema}
>

  <!-- Hero Section -->
  <section class="section" style="padding-top: var(--space-8); background: var(--color-bg-alt); padding-bottom: var(--space-12); position: relative; overflow: hidden;">
    <div style="position: absolute; inset: 0; opacity: 0.05; background: radial-gradient(circle, var(--color-primary) 10%, transparent 80%); pointer-events: none;"></div>
    <div class="container">
      <div class="section-header" style="max-width: 900px; margin: 0 auto; text-align: center;">
        <span class="section-badge">📍 Địa Điểm: {loc.name} {loc.mergedFrom && <span style="font-size: 11px; opacity: 0.8; font-weight: normal; margin-left: 6px;">({loc.mergedFrom})</span>}</span>
        <h1 class="section-title" style="font-size: var(--text-3xl); line-height: 1.2; font-weight: 800; margin-bottom: var(--space-4);">{loc.headline}</h1>
        <p class="section-subtitle" style="margin: 0 auto var(--space-8); max-width: 700px;">
          {loc.subtitle}
        </p>
        <div class="hero-cta" style="display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap;">
          <a href="tel:0979121097" class="btn btn-accent btn-lg pulse">📞 Hotline: 0979.121.097</a>
          <a href="#dia-diem-hoc-boi" class="btn btn-primary btn-lg">🏊 Danh Sách Bể Bơi</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section">
    <div class="container" style="max-width: 1100px;">
      <div class="grid grid-2" style="gap: var(--space-10); align-items: start; margin-bottom: var(--space-16);">
        <div>
          <h2 style="font-size: var(--text-2xl); color: var(--color-primary); margin-bottom: var(--space-4); font-weight: 700;">Dạy Học Bơi Tại {loc.name} Cho Trẻ Em & Người Lớn</h2>
          <p style="color: var(--color-text-secondary); line-height: 1.8; margin-bottom: var(--space-4); font-size: var(--text-base);">
            {loc.intro}
          </p>
          <p style="color: var(--color-text-secondary); line-height: 1.8; margin-bottom: var(--space-6); font-size: var(--text-base);">
            Tại {loc.name}, <strong>Swim For Life Việt Nam</strong> triển khai mô hình dạy học bơi kèm riêng biệt (1 kèm 1, 1 kèm 2) chuẩn quốc tế. HLV sẽ thiết kế giáo án phù hợp với thể lực và mức độ tự tin dưới nước của từng học viên, cam kết giúp học viên tự tin bơi lội chỉ sau 10-12 buổi.
          </p>
          <div style="background: var(--color-bg-alt); padding: var(--space-5); border-radius: 12px; border-left: 4px solid var(--color-accent);">
            <strong style="display: block; color: var(--color-accent); margin-bottom: 2px; font-size: var(--text-base);">💯 Cam kết từ Swim For Life:</strong>
            <span style="font-size: var(--text-sm); color: var(--color-text-secondary); line-height: 1.5;">Nếu học viên đi học chuyên cần nhưng chưa biết bơi sau kết thúc số buổi học quy định, trung tâm cam kết dạy tiếp hoàn toàn miễn phí cho tới khi học viên bơi thành thạo.</span>
          </div>
        </div>
        <div>
          <img 
            src={loc.image} 
            alt={`Lớp dạy học bơi chuyên nghiệp uy tín tại ${loc.name} do HLV Swim For Life Việt Nam đứng lớp`} 
            style="border-radius: 16px; box-shadow: var(--shadow-lg); width: 100%; object-fit: cover; height: 380px;"
            loading="eager"
          />
        </div>
      </div>

      <!-- Pools Section -->
      <div id="dia-diem-hoc-boi" style="scroll-margin-top: 100px; margin-bottom: var(--space-16);">
        <h2 style="font-size: var(--text-2xl); color: var(--color-primary); text-align: center; margin-bottom: var(--space-2); font-weight: 700;">Hệ Thống Bể Bơi Hợp Tác Tại {loc.name}</h2>
        <p style="text-align: center; color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--space-8); font-size: var(--text-sm);">
          Học viên có thể chủ động lựa chọn một trong các địa điểm bể bơi đối tác tiện lợi dưới đây, hoặc đề xuất bể bơi gần nhà mình để HLV tới giảng dạy.
        </p>

        <div class="grid grid-3" style="gap: var(--space-6);">
          {loc.pools.map((pool) => (
            <div class="card" style="padding: var(--space-5); border-radius: 16px; box-shadow: var(--shadow-sm); background: #ffffff; border: 1px solid var(--color-border); display: flex; flex-direction: column; justify-content: space-between;">
              <div>
                <span style="font-size: 20px; margin-bottom: var(--space-2); display: block;">🏊</span>
                <h3 style="font-size: var(--text-base); font-weight: 700; color: var(--color-text); margin-bottom: var(--space-2);">{pool.name}</h3>
                <p style="font-size: var(--text-xs); color: var(--color-text-secondary); margin-bottom: var(--space-4); line-height: 1.4;"><strong>📍 Địa chỉ:</strong> {pool.address}</p>
                <p style="font-size: var(--text-xs); color: var(--color-text-secondary); margin-bottom: var(--space-4);"><strong>🎨 Thiết kế:</strong> {pool.type}</p>
              </div>
              <div style="border-top: 1px solid var(--color-border-light); padding-top: var(--space-3); font-size: var(--text-xs); color: var(--color-text-secondary); line-height: 1.4;">
                <strong>⭐ Điểm cộng:</strong> {pool.pros}
              </div>
            </div>
          ))}
          
          <!-- Add Request Box -->
          <div class="card" style="padding: var(--space-5); border-radius: 16px; background: var(--color-bg-alt); border: 1px dashed var(--color-primary); display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center; min-height: 200px;">
            <span style="font-size: 24px; margin-bottom: var(--space-2);">❓</span>
            <h3 style="font-size: var(--text-base); font-weight: 700; color: var(--color-primary); margin-bottom: var(--space-2);">Bể bơi khác gần bạn?</h3>
            <p style="font-size: var(--text-xs); color: var(--color-text-secondary); line-height: 1.5; max-width: 200px; margin-bottom: var(--space-4);">Chúng tôi sẵn sàng cử giáo viên tới dạy kèm riêng tại bất kỳ bể bơi nào theo yêu cầu của học viên.</p>
            <a href="tel:0979121097" style="font-size: var(--text-xs); font-weight: 700; color: var(--color-accent);">Liên Hệ Ngay →</a>
          </div>
        </div>
      </div>

      <!-- FAQ Section -->
      <div style="margin-bottom: var(--space-16);">
        <div class="loc-faq-layout">
          <div class="loc-faq-info">
            <span class="section__badge" style="display: inline-block; background: var(--color-primary-50); color: var(--color-primary-dark); padding: var(--space-2) var(--space-4); border-radius: var(--radius-full); font-size: var(--text-sm); font-weight: 600; margin-bottom: var(--space-4);">Giải Đáp</span>
            <h2 style="font-size: var(--text-2xl); color: var(--color-primary); margin-bottom: var(--space-4); font-weight: 700; line-height: 1.25;">Hỏi Đáp Về Khóa Học Bơi Tại {loc.name}</h2>
            <p style="color: var(--color-text-secondary); margin-bottom: 24px; font-size: 0.95rem; line-height: 1.6;">
              Những câu hỏi thường gặp nhất của học viên và phụ huynh khi đăng ký các lớp dạy học bơi ở {loc.name}.
            </p>
            <div style="width: 60px; height: 4px; background: var(--gradient-primary); border-radius: var(--radius-full); margin-bottom: 24px;"></div>
            <div class="loc-faq-cta hide-mobile" style="margin-top: 30px; padding: 24px; background: var(--color-bg-alt); border-radius: var(--radius-lg); border: 1px solid rgba(0, 119, 182, 0.05);">
              <p style="font-weight: 600; color: var(--color-primary); margin-bottom: 8px;">Bạn cần hỗ trợ trực tiếp?</p>
              <p style="font-size: 0.85rem; line-height: 1.5; margin-bottom: 16px; color: var(--color-text-secondary);">Liên hệ HLV Trưởng để được giải đáp mọi thắc mắc và đặt lịch bơi thử miễn phí.</p>
              <a href="tel:0979121097" class="btn btn--accent btn--sm" style="display: inline-flex; align-items: center; gap: 8px; justify-content: center; text-decoration: none; background: var(--gradient-coral); color: white; padding: var(--space-2) var(--space-4); border-radius: var(--radius-full); font-weight: 600;">
                <span>📞</span> Hotline: 0979.121.097
              </a>
            </div>
          </div>

          <div class="faq-list" style="display: flex; flex-direction: column; gap: var(--space-4); width: 100%;">
            {loc.faqs.map((faq, index) => (
              <details class="faq-card" open={index === 0} style="background: #ffffff; border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; transition: all var(--transition-base); padding: 0;">
                <summary class="faq-card__q" style="font-size: 1.05rem; font-weight: 700; color: var(--color-dark); padding: var(--space-5) var(--space-6); display: flex; justify-content: space-between; align-items: center; cursor: pointer; list-style: none; user-select: none; gap: var(--space-4); margin-bottom: 0;">
                  <span>{faq.q}</span>
                  <span class="faq-card__icon"></span>
                </summary>
                <div class="faq-card__answer-wrap">
                  <p class="faq-card__a" style="font-size: 0.9rem; color: var(--color-text-secondary); line-height: 1.75; margin-bottom: 0;">{faq.a}</p>
                </div>
              </details>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>

  <CoachesSection />

  <!-- Register Form Container -->
  <section class="section" style="background: var(--color-bg-alt); padding-block: var(--space-12);">
    <div class="container" style="max-width: 900px;">
      <div class="grid grid-2" style="gap: var(--space-8); align-items: center; background: #ffffff; border-radius: 20px; box-shadow: var(--shadow-xl); padding: var(--space-8);">
        <div>
          <h2 style="font-size: var(--text-2xl); color: var(--color-primary); margin-bottom: var(--space-3); font-weight: 700;">Đăng Ký Học Thử Tại {loc.name}</h2>
          <p style="color: var(--color-text-secondary); line-height: 1.6; margin-bottom: var(--space-4);">
            Vui lòng gửi thông tin liên hệ. Giáo viên của trung tâm tại {loc.name} sẽ chủ động gọi điện tư vấn và sắp xếp lịch bơi thử hoàn toàn miễn phí cho bạn.
          </p>
          <div style="display: flex; flex-direction: column; gap: var(--space-2); font-size: var(--text-sm);">
            <div><strong>📞 Hotline 24/7:</strong> <a href="tel:0979121097" style="color: var(--color-accent); font-weight: 600;">0979.121.097</a></div>
            <div><strong>💬 Zalo hỗ trợ:</strong> <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" style="color: var(--color-accent); font-weight: 600;">0979.121.097 (Thầy Mạnh)</a></div>
          </div>
        </div>
        <div style="border-left: 1px solid var(--color-border); padding-left: var(--space-8);">
          <RegistrationForm id="location-page-form" isFullForm={false} flat={true} />
        </div>
      </div>
    </div>
  </section>

</PageLayout>

<style>
  /* Local FAQ 2-column styles for Location pages */
  .loc-faq-layout {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: 60px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: start;
  }

  .loc-faq-info {
    position: sticky;
    top: 100px;
  }

  @media (max-width: 991px) {
    .loc-faq-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .loc-faq-info {
      position: static;
      text-align: center;
    }
  }

  /* Zero JS accordion summary */
  .faq-card__q::-webkit-details-marker {
    display: none;
  }

  .faq-card__icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--color-bg-alt);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: all 0.4s ease;
  }

  .faq-card__icon::before,
  .faq-card__icon::after {
    content: '';
    position: absolute;
    background-color: var(--color-primary);
    transition: transform 0.3s ease;
  }

  /* Vertical line */
  .faq-card__icon::before {
    width: 2px;
    height: 12px;
    top: 10px;
    left: 15px;
  }

  /* Horizontal line */
  .faq-card__icon::after {
    width: 12px;
    height: 2px;
    top: 15px;
    left: 10px;
  }

  .faq-card__answer-wrap {
    max-height: 0;
    overflow: hidden;
    padding: 0 var(--space-6);
    opacity: 0;
    transition: all 0.4s ease;
  }

  /* Style for open state */
  details.faq-card[open] {
    border-color: var(--color-primary) !important;
    background: rgba(240, 248, 255, 0.3) !important;
  }

  details.faq-card[open] .faq-card__q {
    color: var(--color-primary) !important;
  }

  details.faq-card[open] .faq-card__icon {
    background: linear-gradient(135deg, var(--color-primary), var(--color-teal));
  }

  details.faq-card[open] .faq-card__icon::before {
    transform: rotate(90deg);
    background-color: #ffffff;
  }

  details.faq-card[open] .faq-card__icon::after {
    transform: rotate(90deg);
    background-color: #ffffff;
    opacity: 0;
  }

  details.faq-card[open] .faq-card__answer-wrap {
    max-height: 500px;
    padding-bottom: var(--space-5);
    opacity: 1;
  }
</style>
