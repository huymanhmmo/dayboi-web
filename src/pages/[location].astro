---
import PageLayout from '../layouts/PageLayout.astro';
import RegistrationForm from '../components/RegistrationForm.astro';
import CoachesSection from '../components/CoachesSection.astro';
import { locations } from '../data/locations.js';
import '../styles/location-page.css';

export function getStaticPaths() {
  return locations.map((loc) => ({
    params: { location: loc.slug },
    props: { loc },
  }));
}

const { loc } = Astro.props;
const currentYear = new Date().getFullYear();

const breadcrumbs = [
  { label: 'Trang chủ', href: '/' },
  { label: `Học bơi ${loc.name}` },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": loc.title,
  "description": loc.description,
  "author": {
    "@type": "Person",
    "name": "Thầy Nguyễn Huy Mạnh",
    "jobTitle": "Giám đốc đào tạo",
    "affiliation": {
      "@type": "Organization",
      "name": "Swim For Life Việt Nam"
    }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Swim For Life Việt Nam",
    "logo": {
      "@type": "ImageObject",
      "url": "https://dayboi.vip/images/brand/logo.png"
    }
  },
  "datePublished": "2026-01-25",
  "dateModified": "2026-06-10",
  "image": `https://dayboi.vip${loc.image}`,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://dayboi.vip/${loc.slug}/`
  }
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": `Trung tâm dạy bơi Swim For Life Việt Nam - Chi nhánh ${loc.name}`,
  "description": `Khóa học bơi chuyên nghiệp dạy kèm riêng tại khu vực ${loc.name} và lân cận. Cam kết biết bơi hoàn toàn.`,
  "telephone": "0979121097",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": loc.name,
    "addressCountry": "VN"
  },
  "url": `https://dayboi.vip/${loc.slug}/`,
  "image": `https://dayboi.vip${loc.image}`,
  "priceRange": "Liên hệ nhận báo giá"
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": loc.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
};

const combinedSchema = [articleSchema, localBusinessSchema, faqSchema];

let enSlug = loc.slug.replace('hoc-boi-', 'swimming-lessons-');
if (loc.slug === 'hoc-boi-tphcm') enSlug = 'swimming-lessons-ho-chi-minh';
const alternateUrl = `/en/${enSlug}/`;
---

<PageLayout
  title={`${loc.title} [${currentYear}]`}
  description={loc.description}
  canonical={`https://dayboi.vip/${loc.slug}/`}
  image={loc.image}
  type="article"
  breadcrumbs={breadcrumbs}
  schema={combinedSchema}
  alternateUrl={alternateUrl}
  alternateLang="en"
>

  <!-- ============================================
       HERO SECTION — Premium Full Width Split Screen
       ============================================ -->
  <section class="loc-hero">
    <div class="loc-hero__bg">
      <div class="loc-hero__bg-gradient"></div>
      <div class="loc-hero__bubbles" aria-hidden="true">
        <span class="bubble bubble--1"></span>
        <span class="bubble bubble--2"></span>
        <span class="bubble bubble--3"></span>
        <span class="bubble bubble--4"></span>
        <span class="bubble bubble--5"></span>
      </div>
    </div>
    <div class="container loc-hero__grid">
      <div class="loc-hero__text reveal">
        <div class="loc-hero__badge">
          <span class="loc-hero__badge-dot"></span>
          Trung Tầm Dạy Bơi {loc.name} Uy Tín Số 1 {loc.mergedFrom && `(${loc.mergedFrom})`}
        </div>
        <h1 class="loc-hero__title">
          Dạy Học Bơi <br/>
          <span class="text-gradient">{loc.name}</span> — Lớp Học Bơi<br/>
          <span class="text-accent">Kèm Riêng 1 Kèm 1</span>
        </h1>
        <p class="loc-hero__desc">
          Swim For Life Việt Nam mang đến các khóa học bơi tại {loc.name} chất lượng vượt trội. 
          Lớp dạy bơi kèm riêng biệt 1 kèm 1 tận tâm dưới nước, thiết lập giáo trình riêng cho từng học viên, giúp bạn tự tin bơi lội an toàn chỉ sau 10-12 buổi.
        </p>
        
        <div class="loc-hero__value-props">
          <div class="v-prop">
            <span class="v-prop__icon">🏆</span>
            <div class="v-prop__content">
              <strong>Học thử 1 buổi hoàn toàn miễn phí</strong>
              <span>Trải nghiệm trực tiếp dịch vụ trước khi đưa ra quyết định đăng ký học bơi tại {loc.name}</span>
            </div>
          </div>
          <div class="v-prop">
            <span class="v-prop__icon">🛡️</span>
            <div class="v-prop__content">
              <strong>Bảo hành & Cam kết biết bơi 100%</strong>
              <span>Dạy tiếp hoàn toàn miễn phí nếu học viên đi học đầy đủ mà chưa biết bơi thành thạo</span>
            </div>
          </div>
        </div>

        <div class="loc-hero__actions">
          <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="btn btn--accent btn--lg btn--pulse">
            💬 Đăng Ký Học Thử Miễn Phí
          </a>
          <a href="#dia-diem-hoc-boi" class="btn btn--hero-outline btn--lg">
            🏊 Xem Địa Điểm Bể Bơi
          </a>
        </div>
      </div>

      <div class="loc-hero__visual reveal">
        <div class="loc-hero__water-bubbles" aria-hidden="true">
          <span class="water-bubble wb--1"></span>
          <span class="water-bubble wb--2"></span>
          <span class="water-bubble wb--3"></span>
          <span class="water-bubble wb--4"></span>
          <span class="water-bubble wb--5"></span>
          <span class="water-bubble wb--6"></span>
          <span class="water-bubble wb--7"></span>
          <span class="water-bubble wb--8"></span>
          <span class="water-bubble wb--9"></span>
          <span class="water-bubble wb--10"></span>
        </div>
        <div class="loc-hero__collage">
          <div class="loc-hero__photo loc-hero__photo--main">
            <img 
              src={loc.image} 
              alt={`Lớp dạy học bơi kèm riêng chuyên nghiệp tại ${loc.name} - Swim For Life Việt Nam`} 
              loading="eager"
            />
          </div>
          <div class="loc-hero__photo loc-hero__photo--top">
            <img 
              src="/images/coaches/giao-vien-chinh-sua-ky-thuat.jpg" 
              alt="Giáo viên chỉnh sửa kỹ thuật bơi cho học viên" 
              loading="eager" 
            />
          </div>
          <div class="loc-hero__photo loc-hero__photo--bottom">
            <img 
              src="/images/classes/lop-boi-cu-dan-nhi-vinhomes.jpg" 
              alt={`Lớp học bơi Swim For Life tại ${loc.name}`} 
              loading="eager" 
            />
          </div>
        </div>
        <div class="loc-hero__float-card loc-hero__float-card--top">
          <span class="loc-hero__float-icon">🏆</span>
          <div><strong>{loc.pools.length}+ Bể bơi</strong><span>khắp {loc.name}</span></div>
        </div>
        <div class="loc-hero__float-card loc-hero__float-card--bottom">
          <span class="loc-hero__float-icon">🎯</span>
          <div><strong>100%</strong><span>cam kết biết bơi</span></div>
        </div>
        <div class="loc-hero__float-card loc-hero__float-card--left">
          <span class="loc-hero__float-icon">🌟</span>
          <div><strong>Học thử</strong><span>miễn phí 1 buổi</span></div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       STATISTICS SECTION
       ============================================ -->
  <section class="section loc-stats-section">
    <div class="container">
      <div class="loc-stats-grid reveal">
        <div class="stat-item">
          <span class="stat-item__num">99.8%</span>
          <span class="stat-item__label">Học viên biết bơi hoàn toàn</span>
        </div>
        <div class="stat-item">
          <span class="stat-item__num">{loc.pools.length}+</span>
          <span class="stat-item__label">Chỗ học bơi ở {loc.name} khang trang</span>
        </div>
        <div class="stat-item">
          <span class="stat-item__num">12+</span>
          <span class="stat-item__label">Năm kinh nghiệm đào tạo</span>
        </div>
        <div class="stat-item">
          <span class="stat-item__num">3000+</span>
          <span class="stat-item__label">Học viên tốt nghiệp hàng năm</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       INTRO SECTION
       ============================================ -->
  <section class="section section--alt loc-intro-section">
    <div class="container">
      <div class="loc-intro-grid reveal">
        <div class="loc-intro-text">
          <span class="section__badge">Về Lớp Học</span>
          <h2 class="section__title">Dạy Bơi {loc.name} <span class="text-gradient">An Toàn & Hiệu Quả</span></h2>
          <p class="about-text" style="color: var(--color-text-secondary); line-height: 1.8; margin-bottom: var(--space-4); font-size: var(--text-base);">
            {loc.intro}
          </p>
          <p class="about-text" style="color: var(--color-text-secondary); line-height: 1.8; margin-bottom: var(--space-6); font-size: var(--text-base);">
            Tại các **trung tâm dạy bơi {loc.name}**, Swim For Life tự hào đi đầu trong việc áp dụng mô hình kèm riêng biệt (1 HLV kèm tối đa 2 học viên), giúp giáo viên bám sát học viên 100% thời gian dưới nước, khắc phục chứng sợ nước và sửa lỗi động tác chính xác. Học viên được chủ động chọn địa điểm học bơi ở {loc.name} gần nhà mình nhất.
          </p>
          
          <div class="loc-intro-features">
            <div class="intro-feat">
              <span class="intro-feat__icon">✅</span>
              <span>Đội ngũ giáo viên dạy bơi tại {loc.name} chuyên nghiệp, tốt nghiệp chuyên ngành bơi lội ĐH TDTT.</span>
            </div>
            <div class="intro-feat">
              <span class="intro-feat__icon">✅</span>
              <span>Học viên chủ động sắp xếp thời gian biểu học linh hoạt từ 6h00 đến 21h00 hàng ngày.</span>
            </div>
            <div class="intro-feat">
              <span class="intro-feat__icon">✅</span>
              <span>Đầy đủ giáo viên Nam và Nữ, đáp ứng nhu cầu học kèm riêng kín đáo, kiên nhẫn.</span>
            </div>
          </div>
        </div>
        <div class="loc-intro-image-wrap">
          <img 
            src="/images/classes/lop-boi-cu-dan-nhi-vinhomes.jpg" 
            alt={`Lớp dạy bơi cho trẻ em và người lớn tại ${loc.name}`} 
            class="loc-intro-img"
            loading="lazy"
          />
          <div class="img-caption">Lớp học bơi kèm riêng vui vẻ và chất lượng tại {loc.name}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       PARTNER POOLS GRID
       ============================================ -->
  <section class="section loc-pools-section" id="dia-diem-hoc-boi">
    <div class="container">
      <div class="section__header text-center reveal">
        <span class="section__badge">Địa Điểm Thực Hành</span>
        <h2 class="section__title">Địa Điểm Học Bơi Ở {loc.name} — <span class="text-gradient">Bể Thực Hành</span></h2>
        <p class="section__desc">Chúng tôi hợp tác với hệ thống bể bơi lớn, khang trang và sạch sẽ tại {loc.name} để mang lại sự tiện lợi tối đa cho bạn khi đăng ký dạy bơi.</p>
      </div>

      <div class="loc-pools-grid reveal">
        {loc.pools.map((pool, index) => (
          <div class="pool-card">
            <div class="pool-card__header">
              <span class="pool-card__icon">🏊</span>
              <span class="pool-card__badge">{index === 0 ? "Bể bơi trọng điểm" : "Bể thực hành"}</span>
            </div>
            <div class="pool-card__body">
              <h3 class="pool-card__title">{pool.name}</h3>
              <p class="pool-card__detail"><strong>📍 Địa chỉ:</strong> {pool.address}</p>
              <p class="pool-card__detail"><strong>🎨 Loại bể:</strong> {pool.type}</p>
              <div class="pool-card__pros">
                <strong>⭐ Điểm nổi bật:</strong>
                <span>{pool.pros}</span>
              </div>
            </div>
            <div class="pool-card__footer">
              <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="pool-card__btn">
                Đăng ký lớp học bơi tại đây →
              </a>
            </div>
          </div>
        ))}

        <!-- Custom Request Pool Card -->
        <div class="pool-card pool-card--request">
          <div class="pool-card__request-content">
            <span class="request-icon">❓</span>
            <h3 class="pool-card__title">Bạn muốn học bể bơi khác?</h3>
            <p class="pool-card__request-desc">Chúng tôi nhận dạy kèm riêng tại nhà hoặc bất kỳ bể bơi nào theo yêu cầu của học viên tại {loc.name}.</p>
            <a href="tel:0979121097" class="btn btn--accent btn--sm">
              📞 Gọi 0979.121.097
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       COURSE PROGRAMS GRID
       ============================================ -->
  <section class="section section--alt loc-programs-section">
    <div class="container">
      <div class="section__header text-center reveal">
        <span class="section__badge">Chương Trình Đào Tạo</span>
        <h2 class="section__title">Khóa Học Bơi {loc.name} <span class="text-gradient">Cho Mọi Lứa Tuổi</span></h2>
        <p class="section__desc">Lựa chọn chương trình học phù hợp với nhu cầu và lứa tuổi của bạn. Cam kết đầu ra lớp học bơi chất lượng nhất.</p>
      </div>

      <div class="loc-programs-grid reveal">
        <!-- Program 1 -->
        <div class="program-card">
          <div class="program-card__img-wrap">
            <img src="/images/classes/lop-boi-tre-em-bai-ban.jpg" alt={`Học bơi trẻ em tại ${loc.name}`} />
            <span class="program-card__tag">Dành cho trẻ em</span>
          </div>
          <div class="program-card__body">
            <h3 class="program-card__title">Học Bơi Trẻ Em {loc.name}</h3>
            <p class="program-card__desc">Lớp học bơi cho bé ở {loc.name} từ 5-15 tuổi. Giáo trình chuẩn giúp bé tự tin phản xạ dưới nước, học bơi cơ bản bài bản và rèn kỹ năng phòng chống đuối nước tự cứu mình.</p>
            <ul class="program-card__list">
              <li>⏱️ Số buổi: 10 - 12 buổi (60 phút/buổi)</li>
              <li>👨 HLV kèm sát sao dưới nước</li>
              <li>🛡️ Học thử 1 buổi miễn phí</li>
            </ul>
          </div>
          <div class="program-card__footer">
            <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--full">Đăng Ký Khóa Trẻ Em</a>
          </div>
        </div>

        <!-- Program 2 -->
        <div class="program-card">
          <div class="program-card__img-wrap">
            <img src="/images/classes/hoc-vien-chinh-sua-trong-nuoc.jpg" alt={`Học bơi người lớn tại ${loc.name}`} />
            <span class="program-card__tag program-card__tag--orange">Dành cho người lớn</span>
          </div>
          <div class="program-card__body">
            <h3 class="program-card__title">Học Bơi Người Lớn {loc.name}</h3>
            <p class="program-card__desc">Lớp học bơi cho người lớn ở {loc.name} (từ 16 tuổi trở lên). Giáo án cá nhân hóa hỗ trợ học viên nhát nước lâu năm vượt qua nỗi sợ hãi, bơi ếch, bơi sải tự tin.</p>
            <ul class="program-card__list">
              <li>⏱️ Lịch học linh hoạt do học viên sắp xếp</li>
              <li>🏊 Học bơi Ếch cơ bản hoặc bơi Sải nâng cao</li>
              <li>🛡️ Cam kết biết bơi hoàn toàn 100%</li>
            </ul>
          </div>
          <div class="program-card__footer">
            <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="btn btn--primary btn--full">Đăng Ký Khóa Người Lớn</a>
          </div>
        </div>

        <!-- Program 3 -->
        <div class="program-card">
          <div class="program-card__img-wrap">
            <img src="/images/classes/to-chuc-tap-luyen-bai-ban-chuyen-nghiep.jpg" alt={`Dạy bơi kèm riêng tại ${loc.name}`} />
            <span class="program-card__tag program-card__tag--green">1 Kèm 1 Đỉnh Cao</span>
          </div>
          <div class="program-card__body">
            <h3 class="program-card__title">Dạy Bơi Kèm Riêng 1 Kèm 1</h3>
            <p class="program-card__desc">Khóa học bơi kèm riêng tại {loc.name} an toàn nhất. Có lớp học bơi giáo viên nam/nữ theo yêu cầu cho trẻ em hoặc học viên cần sự kiên nhẫn tỉ mỉ.</p>
            <ul class="program-card__list">
              <li>🎯 1 Giáo viên kèm tối đa 2 học viên dưới nước</li>
              <li>🛡️ An toàn tuyệt đối 100%</li>
              <li>🎨 Tùy chọn giáo viên Nam/Nữ</li>
            </ul>
          </div>
          <div class="program-card__footer">
            <a href="https://zalo.me/0979121097" target="_blank" rel="noopener noreferrer" class="btn btn--accent btn--full btn--pulse">Đăng Ký Lớp 1 Kèm 1</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================
       SWIM TECHNIQUES PREVIEW
       ============================================ -->
  <section class="section techniques-section" id="techniques-preview">
    <div class="container">
      <div class="section__header text-center reveal">
        <span class="section__badge">Kỹ Thuật Bơi</span>
        <h2 class="section__title">4 Kỹ Thuật Bơi <span class="text-gradient">Cơ Bản & Nâng Cao</span></h2>
        <p class="section__desc">Hệ thống giáo trình đào tạo đầy đủ 4 kiểu bơi từ cơ bản đến nâng cao</p>
      </div>
      <div class="techniques-grid">
        <a href="/ky-thuat-boi/hoc-boi-ech/" class="technique-card reveal">
          <div class="technique-card__img-wrap">
            <img src="/images/techniques/huong-dan-tap-tho-boi-ech.jpg" alt="Hướng dẫn tập thở bơi ếch - Kỹ thuật bơi ếch cơ bản" loading="lazy" />
          </div>
          <div class="technique-card__body">
            <span class="technique-card__number">01</span>
            <h3 class="technique-card__title">Bơi Ếch</h3>
            <p class="technique-card__desc">Kiểu bơi phổ biến nhất, dễ học, phù hợp cho người mới bắt đầu.</p>
            <span class="technique-card__link">Xem chi tiết →</span>
          </div>
        </a>
        <a href="/ky-thuat-boi/hoc-boi-sai/" class="technique-card reveal">
          <div class="technique-card__img-wrap">
            <img src="/images/techniques/tap-dong-tac-tay-boi-sai-tren-can.jpg" alt="Tập động tác tay bơi sải trên cạn - Kỹ thuật bơi sải" loading="lazy" />
          </div>
          <div class="technique-card__body">
            <span class="technique-card__number">02</span>
            <h3 class="technique-card__title">Bơi Sải</h3>
            <p class="technique-card__desc">Kiểu bơi nhanh nhất, còn gọi là bơi trườn sấp (Front Crawl).</p>
            <span class="technique-card__link">Xem chi tiết →</span>
          </div>
        </a>
        <a href="/ky-thuat-boi/hoc-boi-ngua/" class="technique-card reveal">
          <div class="technique-card__img-wrap">
            <img src="/images/safety/khoi-dong-tren-can.jpg" alt="Khởi động trên cạn trước khi tập bơi ngửa - Kỹ thuật bơi ngửa" loading="lazy" />
          </div>
          <div class="technique-card__body">
            <span class="technique-card__number">03</span>
            <h3 class="technique-card__title">Bơi Ngửa</h3>
