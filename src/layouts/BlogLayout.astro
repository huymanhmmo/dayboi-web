---
import PageLayout from './PageLayout.astro';
import AuthorBio from '../components/AuthorBio.astro';
import RegistrationForm from '../components/RegistrationForm.astro';
import SuccessModal from '../components/SuccessModal.astro';
import { blogPosts } from '../data/blogPosts.js';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  breadcrumbs: Array<{ label: string; href?: string }>;
  schema?: object;
  category?: string;
  readTime?: string;
  publishDate?: string;
  featuredImage: string;
  featuredImageAlt: string;
  intro: string;
  tocItems: Array<{ id: string; text: string }>;
  lang?: 'vi' | 'en';
}

const {
  title,
  description,
  canonical,
  breadcrumbs,
  schema,
  category,
  readTime,
  publishDate,
  featuredImage,
  featuredImageAlt,
  intro,
  tocItems,
  lang = 'vi'
} = Astro.props;

const currentYear = new Date().getFullYear();

// Clean up title to make a nice H1 without meta tags or year brackets
const cleanHeadline = title.replace(/\s*\[.*?\]/g, '').trim();

// Extract slug to identify current post
const currentSlug = Astro.url.pathname.split('/').filter(Boolean).pop() || '';

// Dynamically resolve category, tags, dates and read times from central blogPosts data if possible
const matchedPost = blogPosts.find(post => post.slug === currentSlug);
const resolvedCategory = matchedPost ? (lang === 'en' ? 'Swimming Guides' : matchedPost.category) : (category || (lang === 'en' ? 'Swimming Guides' : 'Kiến thức bơi'));
const resolvedCategorySlug = matchedPost ? matchedPost.categorySlug : (lang === 'en' ? 'en/guides' : 'huong-dan-hoc-boi');
const resolvedTags = matchedPost ? matchedPost.tags : [];
const resolvedTagSlugs = matchedPost ? matchedPost.tagSlugs : [];
const resolvedReadTime = matchedPost ? (lang === 'en' ? matchedPost.readTime.replace('phút đọc', 'min read') : matchedPost.readTime) : (readTime || (lang === 'en' ? '10 min read' : '10 phút'));
const resolvedPublishDate = matchedPost ? matchedPost.date : (publishDate || (lang === 'en' ? '05/25' : '20/05'));

// Get related posts (prioritize same category, max 8 posts)
const englishRecentPosts = [
  {
    title: 'Ultimate Swimming Guide for Beginners',
    slug: 'en/guides',
    image: '/images/classes/hlv-chuyen-mon-cao-tam-ly.jpeg',
    date: '05/25'
  },
  {
    title: 'How to Swim: Step-by-Step Guide for Beginners',
    slug: 'en/guides/how-to-swim',
    image: '/images/classes/giang-vien-huong-dan-ky-thuat.jpg',
    date: '05/25'
  },
  {
    title: 'Self-Taught Swimming: Safe & Effective Method',
    slug: 'en/guides/self-taught-swimming',
    image: '/images/classes/lop-hoc-boi-tre-em-tphcm.jpg',
    date: '05/25'
  },
  {
    title: 'Children Survival Swimming: Crucial Skills to Prevent Drowning',
    slug: 'en/guides/survival-swimming',
    image: '/images/classes/to-chuc-bai-ban-chuyen-nghiep.jpg',
    date: '05/25'
  }
];

const relatedPosts = lang === 'en'
  ? englishRecentPosts.filter(p => !Astro.url.pathname.includes(p.slug))
  : blogPosts
      .filter(post => post.slug !== currentSlug)
      .sort((a, b) => {
        const aSame = a.categorySlug === resolvedCategorySlug ? 1 : 0;
        const bSame = b.categorySlug === resolvedCategorySlug ? 1 : 0;
        return bSame - aSame; // Sort descending
      })
      .slice(0, 8);

// Compute Category counts dynamically
const categoriesMap = new Map();
blogPosts.forEach(post => {
  if (post.category && post.categorySlug) {
    if (!categoriesMap.has(post.categorySlug)) {
      categoriesMap.set(post.categorySlug, {
        name: post.category,
        slug: post.categorySlug,
        count: 0
      });
    }
    categoriesMap.get(post.categorySlug).count += 1;
  }
});
const categoriesList = Array.from(categoriesMap.values());

// Compute Tag counts dynamically
const tagsMap = new Map();
blogPosts.forEach(post => {
  if (post.tags && post.tagSlugs) {
    post.tags.forEach((tag, idx) => {
      const slug = post.tagSlugs[idx];
      if (slug) {
        if (!tagsMap.has(slug)) {
          tagsMap.set(slug, {
            name: tag,
            slug: slug,
            count: 0
          });
        }
        tagsMap.get(slug).count += 1;
      }
    });
  }
});
const tagsList = Array.from(tagsMap.values());

---

<PageLayout
  title={title}
  description={description}
  canonical={canonical}
  type="article"
  breadcrumbs={breadcrumbs}
  schema={schema}
  lang={lang}
>
  <!-- Premium Header (Side-by-Side) -->
  <section class="blog-header-section">
    <div class="container container-wide">
      <div class="blog-header-grid">
        <!-- Left Column: Title & Metadata -->
        <div class="blog-header-left">
          <div class="blog-header-meta">
            <a href={`/${resolvedCategorySlug}/`} class="blog-header-category-link">{resolvedCategory}</a>
            <span class="blog-header-dot">•</span>
            <span class="blog-header-read-time">{resolvedReadTime}</span>
            <span class="blog-header-dot">•</span>
            <span class="blog-header-date">{lang === 'en' ? 'Updated: ' : 'Cập nhật: '}{resolvedPublishDate}/<span class="current-year">{currentYear}</span></span>
          </div>
          
          <h1 class="blog-header-title">{cleanHeadline}</h1>
          <p class="blog-header-intro" set:html={intro} />
          
          <div class="author-card-premium">
            <div class="author-avatar-wrapper">
              <img src="/images/team/thay-nguyen-huy-manh.png" alt={lang === 'en' ? 'Coach Nguyen Huy Manh' : 'Thầy Nguyễn Huy Mạnh'} width="50" height="50" loading="eager" />
            </div>
            <div class="author-details">
              <strong>{lang === 'en' ? 'Coach Nguyen Huy Manh' : 'Thầy Nguyễn Huy Mạnh'}</strong>
              <div class="author-meta-info">
                <span>{lang === 'en' ? '🏆 Head Coach of Swim For Life' : '🏆 HLV Trưởng Swim For Life'}</span>
                <span>•</span>
                <span>{lang === 'en' ? 'Updated: ' : 'Cập nhật: '}{resolvedPublishDate}/<span class="current-year">{currentYear}</span></span>
              </div>
            </div>
          </div>
        </div>
        
        <!-- Right Column: Featured Image -->
        <div class="blog-header-right">
          <div class="blog-header-image-wrapper">
            <img src={featuredImage} alt={featuredImageAlt} width="640" height="360" class="blog-header-image" loading="eager" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Article 3-Column Layout -->
  <article class="blog-article-section">
    <div class="container container-wide">
      <div class="blog-layout-3cols">
        
        <!-- Left Column: Sticky Table of Contents -->
        {tocItems && tocItems.length > 0 && (
          <aside class="blog-sidebar-left">
            <div class="sidebar-widget toc-sidebar-widget">
              <h3 class="widget-title">📑 {lang === 'en' ? 'Table of Contents' : 'Mục Lục'}</h3>
              <nav class="toc-list" aria-label={lang === 'en' ? 'Article table of contents (desktop)' : 'Mục lục bài viết (bản máy tính)'}>
                {tocItems.map(item => (
                  <a href={`#${item.id}`}>{item.text}</a>
                ))}
              </nav>
            </div>
          </aside>
        )}

        <!-- Center Column: Main Content -->
        <div class="blog-content">
          <!-- TOC for Mobile & Tablet -->
          {tocItems && tocItems.length > 0 && (
            <div class="mobile-toc">
              <h2 style="font-size: var(--text-lg); font-weight: 700; margin-bottom: var(--space-3); border: none; padding: 0;">📑 {lang === 'en' ? 'Table of Contents' : 'Mục Lục Bài Viết'}</h2>
              <nav class="toc-list" aria-label={lang === 'en' ? 'Article table of contents (mobile)' : 'Mục lục bài viết (di động)'}>
                {tocItems.map(item => (
                  <a href={`#${item.id}`}>{item.text}</a>
                ))}
              </nav>
            </div>
          )}

          <div class="blog-rich-text">
            <slot />
          </div>

          <!-- Article Tags -->
          {resolvedTags && resolvedTags.length > 0 && (
            <div class="blog-post-tags-row">
              <span class="tags-label">🏷️ {lang === 'en' ? 'Tags:' : 'Thẻ bài viết:'}</span>
              <div class="post-tags-list">
                {resolvedTags.map((tag, index) => (
                  <a href={`/the/${resolvedTagSlugs[index]}/`} class="post-tag-pill">
                    {tag}
                  </a>
                ))}
              </div>
            </div>
          )}

          <!-- Footer Bio -->
          <AuthorBio 
            name={lang === 'en' ? 'Coach Nguyen Huy Manh' : 'Thầy Nguyễn Huy Mạnh'}
            role={lang === 'en' ? 'Founder & Head Coach of Swim For Life Vietnam' : 'Giám Đốc & HLV Trưởng Swim For Life Việt Nam'}
            bio={lang === 'en' ? 'Coach Nguyen Huy Manh graduated from the Physical Education Department of Hanoi National University of Education. With over 10 years of swimming coaching experience from basic to advanced levels, he has successfully taught swimming to more than 10,000 students. He is particularly renowned for his clear teaching methods, strong psychological support for students with water phobia, and helping them overcome their fear of swimming.' : undefined}
          />
        </div>

        <!-- Right Column: Sticky Sidebar (Registration Form + Widgets) -->
        <aside class="blog-sidebar-right">
          <!-- Widget: Categories -->
          <div class="sidebar-widget">
            <h3 class="widget-title">📁 {lang === 'en' ? 'Navigation' : 'Danh Mục'}</h3>
            {lang === 'en' ? (
              <ul class="sidebar-categories-list">
                <li>
                  <a href="/en/courses/" class="category-item-link">
                    <span class="category-name">Swimming Courses</span>
                  </a>
                </li>
                <li>
                  <a href="/en/swimming-techniques/" class="category-item-link">
                    <span class="category-name">Swimming Techniques</span>
                  </a>
                </li>
                <li>
                  <a href="/en/guides/" class="category-item-link">
                    <span class="category-name">Swimming Guides</span>
                  </a>
                </li>
              </ul>
            ) : (
              <ul class="sidebar-categories-list">
                {categoriesList.map(cat => (
                  <li>
                    <a href={`/${cat.slug}/`} class="category-item-link">
                      <span class="category-name">{cat.name}</span>
                      <span class="category-count">({cat.count})</span>
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </div>

          <!-- Widget: Recent Posts -->
          <div class="sidebar-widget">
            <h3 class="widget-title">📰 {lang === 'en' ? 'Recent Articles' : 'Bài Viết Mới'}</h3>
            <div class="recent-posts-list">
              {(lang === 'en' ? englishRecentPosts : blogPosts.slice(0, 10)).map(post => (
                <a href={post.slug.startsWith('http') || post.slug.startsWith('/') ? post.slug : `/${post.slug}/`} class="recent-post-item">
                  <img src={post.image} alt={post.title} class="recent-post-thumb" loading="lazy" width="70" height="70" />
                  <div class="recent-post-info">
                    <h4 class="recent-post-title">{post.title}</h4>
                    <span class="recent-post-meta">📅 {post.date}/{currentYear}</span>
                  </div>
                </a>
              ))}
            </div>
          </div>

          <!-- Widget 2: Form Registration -->
          <div class="sidebar-widget">
            <h3 class="widget-title">{lang === 'en' ? '🏊 Book Free Trial' : '🏊 Đăng Ký Học Thử'}</h3>
            <p class="widget-subtitle">{lang === 'en' ? 'Register today for a free 1-on-1 trial session near your home with our certified coaches.' : 'Nhận ngay 1 buổi học thử 1 kèm 1 miễn phí cùng HLV chuyên nghiệp tại bể bơi gần nhà bạn nhất!'}</p>
            <RegistrationForm id="blog-register-form" lang={lang} />
            <div class="widget-trust">
              {lang === 'en' ? '🔒 Info secured • 100% swim guarantee' : '🔒 Bảo mật thông tin • Cam kết biết bơi 100%'}
            </div>
          </div>
        </aside>

      </div>
    </div>
  </article>

  <!-- Related Posts Section (Có thể bạn quan tâm) -->
  {relatedPosts && relatedPosts.length > 0 && (
    <section class="related-posts-section">
      <div class="container container-wide">
        <h2 class="related-section-title">{lang === 'en' ? '🔍 You May Also Like' : '🔍 Có Thể Bạn Quan Tâm'}</h2>
        <div class="related-posts-grid">
          {relatedPosts.map(post => (
            <article class="related-post-card">
              <a href={post.slug.startsWith('http') || post.slug.startsWith('/') ? post.slug : `/${post.slug}/`} class="related-card-link">
                <div class="related-card-image-wrapper">
                  <img src={post.image} alt={post.title} class="related-card-image" loading="lazy" width="360" height="200" />
                </div>
                <div class="related-card-content">
                  <span class="related-card-category">{lang === 'en' ? 'Swimming Guides' : post.category}</span>
                  <h3 class="related-card-title">{post.title}</h3>
                  <p class="related-card-excerpt">{post.excerpt}</p>
                  <span class="related-card-more">{lang === 'en' ? 'Read post →' : 'Đọc bài viết →'}</span>
                </div>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <SuccessModal />

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const form = document.getElementById('blog-register-form');
      const modal = document.getElementById('success-modal');
      const closeBtn = document.getElementById('close-modal-btn');
      
      if (form && modal && closeBtn) {
        let redirectTimeout;
        let countdownInterval;

        const cancelRedirect = () => {
          clearTimeout(redirectTimeout);
          clearInterval(countdownInterval);
          const redirectHint = modal.querySelector('.modal-redirect-hint');
          if (redirectHint) redirectHint.remove();
        };

        form.addEventListener('submit', (e) => {
          e.preventDefault();

          // Get input values
          const fullname = form.querySelector('[name="fullname"]').value;
          const phone = form.querySelector('[name="phone"]').value;
          const location = form.querySelector('[name="location"]').value;

          // Submit to Google Form Response endpoint asynchronously
          const googleFormUrl = 'https://docs.google.com/forms/d/e/1FAIpQLSe1PwdhtzzkWJaTZ4O79rrCUi4cAwuvmPTqx8TTF8rRleCTqA/formResponse';
          const formData = new URLSearchParams();
          formData.append('entry.1075795830', fullname);
          formData.append('entry.406600670', phone);
          formData.append('entry.1411149651', location);

          fetch(googleFormUrl, {
            method: 'POST',
            mode: 'no-cors',
            headers: {
              'Content-Type': 'application/x-www-form-urlencoded'
            },
            body: formData.toString()
          }).catch(err => console.error('Error submitting to Google Form:', err));

          // Open Zalo in a new tab immediately (prevents browser popup blocker)
          window.open('https://zalo.me/0979121097', '_blank');

          modal.classList.add('active');
          form.reset();

          // Reset any existing timers
          cancelRedirect();

          // Create dynamic countdown element inside success modal
          const card = modal.querySelector('.modal-card');
          let redirectHint = modal.querySelector('.modal-redirect-hint');
          if (!redirectHint && card) {
            redirectHint = document.createElement('p');
            redirectHint.className = 'modal-redirect-hint';
            redirectHint.style.fontSize = '0.9rem';
            redirectHint.style.color = 'var(--color-primary, #0077b6)';
            redirectHint.style.marginTop = '12px';
            redirectHint.style.fontWeight = '600';
            redirectHint.style.textAlign = 'center';
            card.insertBefore(redirectHint, closeBtn);
          }

          const formLang = form.getAttribute('data-lang') || 'vi';

          let secondsLeft = 4;
          if (redirectHint) {
            if (formLang === 'en') {
              redirectHint.innerHTML = `Connected Zalo Coach in a new tab. Closing in <span style="font-size: 1.15rem; color: var(--color-accent, #ff6b35);">${secondsLeft}</span> seconds...`;
            } else {
              redirectHint.innerHTML = `Đã kết nối Zalo HLV ở tab mới. Popup tự đóng sau <span style="font-size: 1.15rem; color: var(--color-accent, #ff6b35);">${secondsLeft}</span> giây...`;
            }
          }

          countdownInterval = setInterval(() => {
            secondsLeft--;
            if (redirectHint) {
              if (formLang === 'en') {
                redirectHint.innerHTML = `Connected Zalo Coach in a new tab. Closing in <span style="font-size: 1.15rem; color: var(--color-accent, #ff6b35);">${secondsLeft}</span> seconds...`;
              } else {
                redirectHint.innerHTML = `Đã kết nối Zalo HLV ở tab mới. Popup tự đóng sau <span style="font-size: 1.15rem; color: var(--color-accent, #ff6b35);">${secondsLeft}</span> giây...`;
              }
            }
            if (secondsLeft <= 0) {
              clearInterval(countdownInterval);
            }
          }, 1000);

          redirectTimeout = setTimeout(() => {
            modal.classList.remove('active');
            cancelRedirect();
          }, 4000);
        });
        
        closeBtn.addEventListener('click', () => {
          modal.classList.remove('active');
          cancelRedirect();
        });
        
        modal.addEventListener('click', (e) => {
          if (e.target === modal) {
            modal.classList.remove('active');
            cancelRedirect();
          }
        });
      }
    });
  </script>
</PageLayout>
