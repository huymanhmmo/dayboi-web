---
import MainLayout from './MainLayout.astro';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
  breadcrumbs?: Array<{ label: string; href?: string }>;
  schema?: object;
  lang?: 'vi' | 'en';
}

const { title, description, canonical, image, type, noindex, breadcrumbs, schema, lang = 'vi' } = Astro.props;
---

<MainLayout 
  title={title} 
  description={description} 
  canonicalUrl={canonical} 
  ogImage={image} 
  noIndex={noindex}
  schema={schema}
  lang={lang}
>
  <Fragment slot="head">
    {breadcrumbs && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": breadcrumbs.map((item, index) => ({
          "@type": "ListItem",
          "position": index + 1,
          "name": item.label,
          ...(item.href ? { "item": `https://dayboi.vip${item.href}` } : {}),
        })),
      })} />
    )}
  </Fragment>

  <Header slot="header" lang={lang} currentPath={Astro.url.pathname} />

  <!-- Breadcrumb -->
  {breadcrumbs && breadcrumbs.length > 0 && (
    <nav class="breadcrumb" aria-label="Breadcrumb" style={`padding-top: var(--space-6); padding-bottom: var(--space-6); background: var(--color-bg-alt);`}>
      <div class="container container-wide">
        <ol class="breadcrumb-list">
          {breadcrumbs.map((item, index) => (
            <li class="breadcrumb-item">
              {index > 0 && <span class="breadcrumb-separator">›</span>}
              {item.href ? (
                <a href={item.href}>{item.label}</a>
              ) : (
                <span>{item.label}</span>
              )}
            </li>
          ))}
        </ol>
      </div>
    </nav>
  )}

  <slot />

  <Footer slot="footer" lang={lang} />
</MainLayout>
